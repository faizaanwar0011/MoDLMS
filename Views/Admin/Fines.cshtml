@model List<MoDLibrary.Models.Fine>
@{
    ViewData["Title"] = "Fines Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var unpaid = Model.Where(f => !f.IsPaid).ToList();
    var paid   = Model.Where(f => f.IsPaid).ToList();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Fines Management</h5>
        <small class="text-muted">Rs. 50/day after 15-day return deadline</small>
    </div>
    <div class="d-flex gap-2">
        <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:120px;">
            <div style="font-size:11px;color:#6c757d;">Unpaid</div>
            <div class="text-danger fw-bold" style="font-size:18px;">Rs. @unpaid.Sum(f => f.FineAmount).ToString("N0")</div>
        </div>
        <div class="card border-0 shadow-sm px-3 py-2 text-center" style="min-width:120px;">
            <div style="font-size:11px;color:#6c757d;">Collected</div>
            <div class="text-success fw-bold" style="font-size:18px;">Rs. @paid.Sum(f => f.FineAmount).ToString("N0")</div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#unpaidTab">Unpaid (@unpaid.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#paidTab">Paid (@paid.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#allFines">All (@Model.Count)</a></li>
</ul>

<div class="tab-content">
    @foreach (var (tabId, list) in new[] {
        ("unpaidTab", unpaid),
        ("paidTab",   paid),
        ("allFines",  Model.ToList())
    })
    {
        <div class="tab-pane fade @(tabId=="unpaidTab"?"show active":"")" id="@tabId">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead style="background:#f8f9fa;">
                                <tr>
                                    <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Member</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">CNIC / Svc No</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Issue Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Due Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Return Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Fine Amount</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Status</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!list.Any())
                                {
                                    <tr><td colspan="9" class="text-center py-4 text-muted">No records.</td></tr>
                                }
                                @foreach (var f in list)
                                {
                                    <tr>
                                        <td class="px-4"><div class="fw-medium" style="font-size:13px;">@f.MemberName</div></td>
                                        <td style="font-size:12px;">
                                            <div>@f.CNIC</div>
                                            <div class="text-muted">@f.ServiceNo</div>
                                        </td>
                                        <td style="font-size:13px;">
                                            <div class="fw-medium">@f.BookTitle</div>
                                            <div class="text-muted" style="font-size:11px;">@f.BookNumber</div>
                                        </td>
                                        <td style="font-size:12px;">@f.IssueDate.ToString("dd MMM yyyy")</td>
                                        <td style="font-size:12px;" class="text-danger">@f.DueDate.ToString("dd MMM yyyy")</td>
                                        <td style="font-size:12px;">@(f.ReturnDate.HasValue ? f.ReturnDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                        <td>
                                            <span class="fw-bold text-danger" style="font-size:15px;">Rs. @f.FineAmount.ToString("N0")</span>
                                        </td>
                                        <td>
                                            @if (f.IsPaid)
                                            {
                                                <span class="badge bg-success-subtle text-success">Paid</span>
                                                <div style="font-size:11px;color:#6c757d;">@(f.PaidDate?.ToString("dd MMM yyyy"))</div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Unpaid</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!f.IsPaid)
                                            {
                                                <form asp-action="MarkFinePaid" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@f.FineId" />
                                                    <button class="btn btn-sm btn-success" onclick="return confirm('Mark this fine as paid?')">
                                                        <i class="bi bi-check2-circle me-1"></i>Mark Paid
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted" style="font-size:12px;">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
