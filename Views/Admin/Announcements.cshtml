@model List<MoDLibrary.Models.Announcement>
@{
    ViewData["Title"] = "Announcements";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Librarian k liye: Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Announcements</h5>
        <small class="text-muted">Post notices for library members</small>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-megaphone me-2"></i>New Announcement
    </button>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-megaphone" style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">No announcements yet.</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var a in Model)
        {
            <div class="card border-0 shadow-sm @(!a.IsActive ? "opacity-50" : "")"
                 style="border-radius:12px;border-left:4px solid #0d6efd !important;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                        <div class="flex-grow-1">
                            <div class="fw-bold mb-1" style="font-size:16px;">
                                <i class="bi bi-megaphone me-2 text-primary"></i>@a.Title
                            </div>
                            <div class="text-muted mb-2" style="font-size:14px;">@a.Message</div>
                            <div class="d-flex gap-3" style="font-size:12px;color:#94a3b8;">
                                <span><i class="bi bi-person me-1"></i>@a.PostedBy</span>
                                <span><i class="bi bi-calendar3 me-1"></i>@a.CreatedAt.ToString("dd MMM yyyy")</span>
                                @if (a.ExpiryDate.HasValue)
                                {
                                    <span class="@(a.ExpiryDate < DateTime.Now ? "text-danger" : "text-success")">
                                        <i class="bi bi-clock me-1"></i>
                                        Expires: @a.ExpiryDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                            </div>
                        </div>
                        @if (a.IsActive)
                        {
                            <form asp-action="DeleteAnnouncement" method="post" style="display:inline;"
                                  onsubmit="return confirm('Remove this announcement?')">
                                <input type="hidden" name="id" value="@a.AnnouncementId" />
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-megaphone me-2 text-primary"></i>New Announcement
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddAnnouncement" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Title <span class="text-danger">*</span></label>
                        <input type="text" name="Title" class="form-control"
                               placeholder="e.g. Library Closed Tomorrow" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Message <span class="text-danger">*</span></label>
                        <textarea name="Message" class="form-control" rows="4"
                                  placeholder="Write your announcement here..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Expiry Date (Optional)</label>
                        <input type="datetime-local" name="ExpiryDate" class="form-control" />
                        <div class="form-text">Leave empty for permanent announcement</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-send me-2"></i>Post Announcement
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
