@model MoDLibrary.Models.LibrarianUser
@{
    ViewData["Title"] = "Edit Librarian";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Librarians" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h5 class="fw-semibold mb-0">Edit Librarian</h5>
        <small class="text-muted">@Model.FullName</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                <form asp-action="EditLibrarian" method="post">
                    <input asp-for="UserId" type="hidden" />
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Full Name <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Username <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-medium" style="font-size:13px;">Account Status</label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveCheck" />
                            <label class="form-check-label" for="isActiveCheck">Account is Active</label>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Librarians" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
