@model List<MoDLibrary.Models.BookRating>
@{
    ViewData["Title"] = "Book Ratings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Librarian k liye: Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Book Ratings & Reviews</h5>
        <small class="text-muted">Member reviews for library books</small>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-star" style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">No ratings yet — members can rate books from the catalog.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Member</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Rating</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Review</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="px-4">
                                    <div class="fw-medium" style="font-size:13px;">@r.BookTitle</div>
                                </td>
                                <td style="font-size:13px;">@r.MemberName</td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <span style="color:@(s <= r.Rating ? "#f59e0b" : "#e2e8f0");font-size:16px;">★</span>
                                        }
                                        <span class="fw-bold ms-1" style="font-size:13px;">@r.Rating/5</span>
                                    </div>
                                </td>
                                <td style="font-size:13px;max-width:250px;color:#6c757d;">
                                    @(string.IsNullOrEmpty(r.Review) ? "—" : r.Review)
                                </td>
                                <td style="font-size:12px;color:#6c757d;">
                                    @r.RatedAt.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
