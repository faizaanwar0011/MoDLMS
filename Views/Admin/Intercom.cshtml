@model List<MoDLibrary.Models.Section>
@{
    ViewData["Title"] = "Intercom Numbers";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Librarian: Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Section Intercom Numbers</h5>
        <small class="text-muted">
            Manage intercom numbers for each section
        </small>
    </div>
</div>

@foreach (var wing in Model.GroupBy(s => s.WingName).OrderBy(g => g.Key))
{
    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px;">
        <div class="card-header bg-white border-bottom py-3 px-4">
            <div class="fw-semibold" style="font-size:14px;">
                <i class="bi bi-diagram-3 me-2 text-primary"></i>
                @wing.Key
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3"
                                style="font-size:11px;text-transform:uppercase;
                                letter-spacing:.5px;color:#6c757d;">
                                Section
                            </th>
                            <th style="font-size:11px;text-transform:uppercase;
                                letter-spacing:.5px;color:#6c757d;">
                                Intercom Number
                            </th>
                            <th style="font-size:11px;text-transform:uppercase;
                                letter-spacing:.5px;color:#6c757d;">
                                Action
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in wing.OrderBy(x => x.SectionName))
                        {
                            <tr>
                                <td class="px-4">
                                    <div class="fw-medium"
                                         style="font-size:13px;">
                                        @s.SectionName
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(s.IntercomNumber))
                                    {
                                        <span class="badge bg-success-subtle
                                            text-success px-3 py-2"
                                              style="font-size:13px;">
                                            <i class="bi bi-telephone me-1"></i>
                                            @s.IntercomNumber
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle
                                            text-secondary"
                                              style="font-size:12px;">
                                            Not set
                                        </span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editIntercomModal"
                                            onclick="setModal(
                                        @s.SectionId,
                                        '@s.SectionName',
                                        '@s.IntercomNumber')">
                                        <i class="bi bi-pencil me-1"></i>
                                        @(string.IsNullOrEmpty(s.IntercomNumber)
                                          ? "Add" : "Edit")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Edit Modal -->
<div class="modal fade" id="editIntercomModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg"
             style="border-radius:16px;">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-telephone me-2 text-primary"></i>
                    Set Intercom Number
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateIntercom" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="sectionId"
                           id="modalSectionId" />
                    <div class="mb-2 fw-medium" id="modalSectionName"
                         style="font-size:14px;"></div>
                    <div class="mb-3">
                        <label class="form-label fw-medium"
                               style="font-size:13px;">
                            Intercom Number
                            <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-telephone text-muted"></i>
                            </span>
                            <input type="text" name="intercomNumber"
                                   id="modalIntercomNum"
                                   class="form-control"
                                   placeholder="e.g. 2234"
                                   required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i>Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setModal(id, name, intercom) {
            document.getElementById('modalSectionId').value    = id;
            document.getElementById('modalSectionName').textContent =
                'Section: ' + name;
            document.getElementById('modalIntercomNum').value  =
                intercom === '—' ? '' : intercom;
        }
    </script>
}