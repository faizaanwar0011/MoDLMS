@{
}
@model MoDLibrary.Models.ReportViewModel
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Librarian: Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<!-- Print Style -->
<style>
    @@media print {
        .no-print {
            display: none !important;
        }

        .card {
            box-shadow: none !important;
            border: 1px solid #dee2e6 !important;
        }

        body {
            background: white !important;
        }

        .container-fluid {
            padding: 0 !important;
        }
    }
</style>

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4 no-print">
    <div>
        <h5 class="fw-semibold mb-0">Reports</h5>
        <small class="text-muted">Generate and download library reports</small>
    </div>
    <button class="btn btn-success" onclick="printReport()">
        <i class="bi bi-download me-2"></i>Download PDF
    </button>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4 no-print" style="border-radius:12px;">
    <div class="card-body p-4">
        <form asp-action="Reports" method="post">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-medium" style="font-size:13px;">Report Type</label>
                    <select asp-for="ReportType" class="form-select"
                            onchange="toggleFilters(this.value)">
                        <option value="Issued">Issued Books Report</option>
                        <option value="Fines">Fines Report</option>
                        <option value="Daily">Daily Activity</option>
                    </select>
                </div>
                <div class="col-md-2" id="startDateDiv">
                    <label class="form-label fw-medium" style="font-size:13px;">From Date</label>
                    <input asp-for="StartDate" type="date" class="form-control"
                           value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2" id="endDateDiv">
                    <label class="form-label fw-medium" style="font-size:13px;">To Date</label>
                    <input asp-for="EndDate" type="date" class="form-control"
                           value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3" id="statusDiv">
                    <label class="form-label fw-medium" style="font-size:13px;">Filter</label>
                    <select asp-for="StatusFilter" class="form-select" id="statusFilter">
                        <option value="All">All</option>
                        <option value="Active">Active</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Returned">Returned</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-2"></i>Generate
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Print Header (only shows when printing) -->
<div class="d-none d-print-block mb-4">
    <div class="text-center">
        <h4 class="fw-bold">Ministry of Defence — MoDLibrary</h4>
        <h5>
            @(Model.ReportType == "Issued" ? "Issued Books Report" :
                        Model.ReportType == "Fines" ? "Fines Report" : "Daily Activity Report")
        </h5>
        <p class="text-muted" style="font-size:13px;">
            Period: @Model.StartDate.ToString("dd MMM yyyy") —
            @Model.EndDate.ToString("dd MMM yyyy") &nbsp;|&nbsp;
            Generated: @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
        </p>
        <hr />
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Issued</div>
                <div class="fw-bold text-primary" style="font-size:22px;">
                    @Model.Summary.TotalIssued
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Returned</div>
                <div class="fw-bold text-success" style="font-size:22px;">
                    @Model.Summary.TotalReturned
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Overdue</div>
                <div class="fw-bold text-danger" style="font-size:22px;">
                    @Model.Summary.CurrentOverdue
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Total Fines</div>
                <div class="fw-bold text-warning" style="font-size:18px;">
                    Rs. @Model.Summary.TotalFines.ToString("N0")
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Collected</div>
                <div class="fw-bold text-success" style="font-size:18px;">
                    Rs. @Model.Summary.CollectedFines.ToString("N0")
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center" style="border-radius:10px;">
            <div class="card-body py-3">
                <div style="font-size:10px;color:#6c757d;text-transform:uppercase;">Pending</div>
                <div class="fw-bold text-danger" style="font-size:18px;">
                    Rs. @Model.Summary.PendingFines.ToString("N0")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── ISSUED BOOKS REPORT ─────────────────────────────────── -->
@if (Model.ReportType == "Issued" && Model.IssuedBooks.Any())
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex
                        align-items-center justify-content-between">
            <span class="fw-semibold" style="font-size:14px;">
                <i class="bi bi-bookmark-check me-2 text-primary"></i>
                Issued Books — @Model.IssuedBooks.Count records
            </span>
            <span style="font-size:12px;color:#6c757d;">
                @Model.StartDate.ToString("dd MMM yyyy") —
                @Model.EndDate.ToString("dd MMM yyyy")
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0"
                       style="font-size:12px;">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-3 py-3">Member</th>
                            <th>CNIC</th>
                            <th>Service No</th>
                            <th>Wing</th>
                            <th>Section</th>
                            <th>Book</th>
                            <th>Issue Date</th>
                            <th>Due Date</th>
                            <th>Return Date</th>
                            <th>Status</th>
                            <th>Fine</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.IssuedBooks)
                        {
                            <tr>
                                <td class="px-3 fw-medium">@r.MemberName</td>
                                <td>@r.CNIC</td>
                                <td>@r.ServiceNo</td>
                                <td>@r.WingName</td>
                                <td>@r.SectionName</td>
                                <td>
                                    <div class="fw-medium">@r.BookTitle</div>
                                    <div class="text-muted" style="font-size:10px;">
                                        @r.BookNumber
                                    </div>
                                </td>
                                <td>@r.IssueDate.ToString("dd MMM yyyy")</td>
                                <td class="@(r.BookStatus == "Overdue" ? "text-danger fw-medium" : "")">
                                    @r.DueDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @(r.ReturnDate.HasValue ?
                                                                r.ReturnDate.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                                <td>
                                    @switch (r.BookStatus)
                                    {
                                        case "Active":
                                            <span class="badge bg-success-subtle text-success">
                                                Active
                                            </span>
                                            break;
                                        case "Overdue":
                                            <span class="badge bg-danger">Overdue</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary-subtle text-secondary">
                                                Returned
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (r.FineAmount > 0)
                                    {
                                        <span class="text-danger fw-medium">
                                            Rs. @r.FineAmount.ToString("N0")
                                        </span>
                                        @if (r.FinePaid)
                                        {
                                            <span class="badge bg-success-subtle text-success ms-1">
                                                Paid
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background:#f8f9fa;">
                        <tr>
                            <td colspan="10" class="px-3 fw-bold text-end">
                                Total Fines:
                            </td>
                            <td class="fw-bold text-danger">
                                Rs. @Model.IssuedBooks.Sum(x => x.FineAmount).ToString("N0")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

<!-- ── FINES REPORT ────────────────────────────────────────── -->
@if (Model.ReportType == "Fines" && Model.Fines.Any())
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex
                        align-items-center justify-content-between">
            <span class="fw-semibold" style="font-size:14px;">
                <i class="bi bi-currency-rupee me-2 text-danger"></i>
                Fines Report — @Model.Fines.Count records
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0"
                       style="font-size:12px;">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-3 py-3">Member</th>
                            <th>CNIC</th>
                            <th>Service No</th>
                            <th>Book</th>
                            <th>Issue Date</th>
                            <th>Due Date</th>
                            <th>Return Date</th>
                            <th>Days Late</th>
                            <th>Fine Amount</th>
                            <th>Status</th>
                            <th>Paid Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in Model.Fines)
                        {
                            <tr>
                                <td class="px-3 fw-medium">@f.MemberName</td>
                                <td>@f.CNIC</td>
                                <td>@f.ServiceNo</td>
                                <td>
                                    <div class="fw-medium">@f.BookTitle</div>
                                    <div class="text-muted" style="font-size:10px;">
                                        @f.BookNumber
                                    </div>
                                </td>
                                <td>@f.IssueDate.ToString("dd MMM yyyy")</td>
                                <td class="text-danger">
                                    @f.DueDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @(f.ReturnDate.HasValue ?
                                                                f.ReturnDate.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                                <td class="text-danger fw-medium">@f.DaysLate</td>
                                <td class="fw-bold text-danger">
                                    Rs. @f.FineAmount.ToString("N0")
                                </td>
                                <td>
                                    @if (f.IsPaid)
                                    {
                                        <span class="badge bg-success-subtle text-success">
                                            Paid
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Unpaid</span>
                                    }
                                </td>
                                <td style="font-size:11px;">
                                    @(f.PaidDate.HasValue ?
                                                                f.PaidDate.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background:#f8f9fa;">
                        <tr>
                            <td colspan="8" class="px-3 fw-bold text-end">Total:</td>
                            <td class="fw-bold text-danger">
                                Rs. @Model.Fines.Sum(f => f.FineAmount).ToString("N0")
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

<!-- ── DAILY ACTIVITY REPORT ──────────────────────────────── -->
@if (Model.ReportType == "Daily" && Model.DailyActivity.Any())
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-header bg-white border-bottom py-3 px-4">
            <span class="fw-semibold" style="font-size:14px;">
                <i class="bi bi-calendar-day me-2 text-info"></i>
                Daily Activity — @Model.StartDate.ToString("dd MMM yyyy")
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0"
                       style="font-size:12px;">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-3 py-3">Activity</th>
                            <th>Member</th>
                            <th>CNIC</th>
                            <th>Service No</th>
                            <th>Book</th>
                            <th>Time</th>
                            <th>Due Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.DailyActivity)
                        {
                            <tr>
                                <td class="px-3">
                                    @if (a.ActivityType == "Issued")
                                    {
                                        <span class="badge bg-primary-subtle text-primary">
                                            <i class="bi bi-bookmark-plus me-1"></i>Issued
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success">
                                            <i class="bi bi-bookmark-check me-1"></i>Returned
                                        </span>
                                    }
                                </td>
                                <td class="fw-medium">@a.MemberName</td>
                                <td>@a.CNIC</td>
                                <td>@a.ServiceNo</td>
                                <td>
                                    <div class="fw-medium">@a.BookTitle</div>
                                    <div class="text-muted" style="font-size:10px;">
                                        @a.BookNumber
                                    </div>
                                </td>
                                <td>@a.ActivityDate.ToString("hh:mm tt")</td>
                                <td>@a.DueDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Empty State -->
@if (!Model.IssuedBooks.Any() && !Model.Fines.Any() && !Model.DailyActivity.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-file-earmark-bar-graph"
           style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">No data found for selected filters.</p>
        <p style="font-size:13px;">Try changing the date range or report type.</p>
    </div>
}

@section Scripts {
    <script>
        function printReport() {
            window.print();
        }

        function toggleFilters(type) {
            const statusSel = document.getElementById('statusFilter');
            statusSel.innerHTML = '';

            if (type === 'Issued') {
                [['All','All'],['Active','Active'],
                 ['Overdue','Overdue'],['Returned','Returned']].forEach(([v,t]) => {
                    const o = document.createElement('option');
                    o.value = v; o.textContent = t;
                    statusSel.appendChild(o);
                });
            } else if (type === 'Fines') {
                [['All','All'],['Paid','Paid'],['Unpaid','Unpaid']].forEach(([v,t]) => {
                    const o = document.createElement('option');
                    o.value = v; o.textContent = t;
                    statusSel.appendChild(o);
                });
            } else {
                const o = document.createElement('option');
                o.value = 'All'; o.textContent = 'All Activity';
                statusSel.appendChild(o);
            }
        }
    </script>
}