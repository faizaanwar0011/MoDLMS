@model List<MoDLibrary.Models.EBook>
@{
    ViewData["Title"] = "Manage E-Books";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    // Librarian: Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">E-Books Management</h5>
        <small class="text-muted">@Model.Count e-books in library</small>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEBookModal">
        <i class="bi bi-plus-circle me-2"></i>Upload E-Book
    </button>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-file-earmark-pdf" style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">No e-books uploaded yet.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;color:#6c757d;">Cover</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Title</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Author</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Category</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Size</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Uploaded</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td class="px-4">
                                    @if (!string.IsNullOrEmpty(e.CoverImagePath))
                                    {
                                        <img src="@e.CoverImagePath" alt="@e.Title"
                                             style="width:36px;height:48px;object-fit:cover;border-radius:4px;" />
                                    }
                                    else
                                    {
                                        <div style="width:36px;height:48px;background:#fef2f2;
                                                                border-radius:4px;display:flex;align-items:center;
                                                                justify-content:center;">
                                            <i class="bi bi-file-pdf text-danger"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-medium" style="font-size:13px;">@e.Title</div>
                                    @if (!string.IsNullOrEmpty(e.Description))
                                    {
                                        <div class="text-muted" style="font-size:11px;">
                                            @(e.Description.Length > 50 ? e.Description.Substring(0, 50) + "…" : e.Description)
                                        </div>
                                    }
                                </td>
                                <td style="font-size:13px;">@e.Author</td>
                                <td style="font-size:13px;">@e.Category</td>
                                <td style="font-size:12px;">@(e.FileSize ?? "—")</td>
                                <td style="font-size:12px;color:#6c757d;">
                                    @e.UploadedAt.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="@e.FilePath" target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="DeleteEBook" method="post"
                                              onsubmit="return confirm('Delete this e-book?')">
                                            <input type="hidden" name="id" value="@e.EBookId" />
                                            <button class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Upload E-Book Modal -->
<div class="modal fade" id="addEBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-upload me-2 text-primary"></i>Upload E-Book
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddEBook" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Title <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="Title" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Author <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="Author" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">Category</label>
                            <select name="CategoryId" class="form-select">
                                <option value="">— Select Category —</option>
                                @foreach (var cat in ViewBag.Categories as List<MoDLibrary.Models.Category> ?? new())
                                {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium" style="font-size:13px;">Published Year</label>
                            <input type="number" name="PublishedYear" class="form-control" placeholder="YYYY" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium" style="font-size:13px;">Total Pages</label>
                            <input type="number" name="TotalPages" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-medium" style="font-size:13px;">Description</label>
                            <textarea name="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                PDF File <span class="text-danger">*</span>
                            </label>
                            <input type="file" name="pdfFile" class="form-control"
                                   accept=".pdf" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Cover Image (Optional)
                            </label>
                            <input type="file" name="coverImage" class="form-control"
                                   accept="image/*" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-upload me-2"></i>Upload E-Book
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
