@model MoDLibrary.Models.Book
@{
    ViewData["Title"] = "Add New Book";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Books" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-semibold mb-0">Add New Book</h5>
        <small class="text-muted">Add a book to the library catalog</small>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                <form asp-action="AddBook" method="post" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-medium" style="font-size:13px;">Book Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter full book title" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium" style="font-size:13px;">Book Number <span class="text-danger">*</span></label>
                            <input asp-for="BookNumber" class="form-control" placeholder="e.g. BK-009" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">Author <span class="text-danger">*</span></label>
                            <input asp-for="Author" class="form-control" placeholder="Author name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">Publisher</label>
                            <input asp-for="Publisher" class="form-control" placeholder="Publisher name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">Shelf Location <span class="text-danger">*</span></label>
                            <input asp-for="ShelfLocation" class="form-control" placeholder="e.g. Shelf A - Row 2" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium" style="font-size:13px;">Total Copies <span class="text-danger">*</span></label>
                            <input asp-for="TotalCopies" type="number" min="1" class="form-control" value="1" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium" style="font-size:13px;">Published Year</label>
                            <input asp-for="PublishedYear" type="number" min="1000" max="2100" class="form-control" placeholder="YYYY" />
                        </div>
                        <!-- Category -->
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select asp-for="CategoryId" class="form-select" required
                                    onchange="loadShelvesAndId(this.value)">
                                <option value="">— Select Category —</option>
                                @foreach (var cat in ViewBag.Categories as List<MoDLibrary.Models.Category> ?? new())
                                {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            </select>
                        </div>

                        <!-- Auto Book ID -->
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Book ID <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="BookNumber" class="form-control" id="bookIdField"
                                       placeholder="Select category first" readonly />
                                <span class="input-group-text bg-success-subtle text-success">
                                    <i class="bi bi-magic"></i> Auto
                                </span>
                            </div>
                        </div>

                        <!-- Shelf -->
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Shelf / Row <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ShelfId" class="form-select" id="shelfSelect" required disabled>
                                <option value="">— Select Category first —</option>
                            </select>
                        </div>

                        <!-- Cover Image -->
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">
                                Cover Image
                            </label>
                            <input type="file" name="coverImage" class="form-control" accept="image/*" />
                            <div class="form-text">JPG or PNG recommended</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium" style="font-size:13px;">ISBN</label>
                            <input asp-for="ISBN" class="form-control" placeholder="ISBN number" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-plus-circle me-2"></i>Add Book
                        </button>
                        <a asp-action="Books" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;background:#f8f9fa;">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-info"></i>Guidelines</h6>
                <ul class="list-unstyled" style="font-size:13px;color:#6c757d;">
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Book Number must be unique (e.g. BK-001)</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Shelf Location format: Shelf X - Row Y</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Total Copies = how many physical copies exist</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Available copies auto-set equal to Total Copies</li>
                </ul>
            </div>
        </div>
    </div>
</div>
