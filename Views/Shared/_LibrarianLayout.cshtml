<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MoDLibrary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="dashboard-body">

<!-- Real-time notification popup container -->
<div id="notif-container" style="position:fixed;top:20px;right:20px;z-index:9999;width:340px;"></div>

<div class="d-flex" style="min-height:100vh;">
    <!-- Sidebar -->
    <nav class="sidebar-nav d-flex flex-column" style="width:240px;min-height:100vh;background:#112240;color:#fff;flex-shrink:0;">
        <div class="px-3 py-4 border-bottom border-secondary">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-book-half fs-4 text-info"></i>
                <div>
                    <div class="fw-bold" style="font-size:15px;">MoDLibrary</div>
                    <div style="font-size:11px;color:#adb5bd;">Ministry of Defence</div>
                </div>
            </div>
        </div>
            <!--<div class="px-3 py-3 border-bottom border-secondary">
                   <div style="font-size:11px;color:#6c757d;text-transform:uppercase;letter-spacing:.8px;">Librarian</div>
                   <div style="font-size:13px;color:#e9ecef;margin-top:2px;">@(ViewBag.User?.FullName ?? "Librarian")</div>
               </div>-->
            <ul class="nav flex-column px-2 py-2 flex-grow-1">
                <li class="nav-item">
                     <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Librarian" asp-action="Dashboard">
                         <i class="bi bi-speedometer2"></i> Dashboard
                     </a>
                 </li>
                <li class="nav-item">
                <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Search"?"active":"")" asp-controller="Librarian" asp-action="Search">
                    <i class="bi bi-search"></i> Search Books
                </a>
            </li>
            <li class="nav-item mt-2">
                <div style="font-size:10px;color:#6c757d;padding:4px 12px;text-transform:uppercase;letter-spacing:.8px;">Catalog</div>
            </li>
            <li class="nav-item">
                <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Books"?"active":"")" asp-controller="Librarian" asp-action="Books">
                    <i class="bi bi-journals"></i> All Books
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="AddBook">
                    <i class="bi bi-plus-circle"></i> Add Book
                </a>
            </li>
            <li class="nav-item mt-2">
                <div style="font-size:10px;color:#6c757d;padding:4px 12px;text-transform:uppercase;letter-spacing:.8px;">Circulation</div>
            </li>
           <!--lass="nav-item">
                <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Requests"?"active":"")" asp-controller="Librarian" asp-action="Requests">
                    <i class="bi bi-inbox"></i> Requests
                    <span id="notif-badge" class="badge bg-danger ms-1" style="display:none;">0</span>
                </a>
            </li>-->
            <li class="nav-item">
                <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="IssuedBooks"?"active":"")" asp-controller="Librarian" asp-action="IssuedBooks">
                    <i class="bi bi-bookmark-check"></i> Issued Books
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Fines"?"active":"")" asp-controller="Librarian" asp-action="Fines">
                    <i class="bi bi-currency-rupee"></i> Fines
                </a>
            </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Suggestions">
                        <i class="bi bi-lightbulb"></i> Suggestions
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Announcements">
                        <i class="bi bi-megaphone"></i> Announcements
                    </a>
                </li>
                <!--<li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Reservations">
                        <i class="bi bi-bookmark-check"></i> Reservations
                    </a>
                </li>-->
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="MemberHistory">
                        <i class="bi bi-clock-history"></i> Member History
                    </a>
                </li>
                <li class="nav-item">
                      <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="PopularBooks">
                          <i class="bi bi-trophy"></i> Popular Books
                      </a>
                  </li>
                <!--<li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Ratings">
                        <i class="bi bi-star"></i> Ratings
                    </a>
                </li>-->
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="IssueBookDirect">
                        <i class="bi bi-bookmark-plus"></i> Issue Book
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="EBooks">
                        <i class="bi bi-file-earmark-pdf"></i> E-Books
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Subscriptions">
                        <i class="bi bi-globe"></i> Subscriptions
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Categories">
                        <i class="bi bi-folder2-open"></i> Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Shelves">
                        <i class="bi bi-archive"></i> Shelves
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link" asp-controller="Librarian" asp-action="Reports">
                        <i class="bi bi-file-earmark-bar-graph"></i> Reports
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link
       @(ViewContext.RouteData.Values["action"]?.ToString() == "Members" ? "active" : "")"
                       asp-controller="Librarian" asp-action="Members">
                        <i class="bi bi-people"></i> Members
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link"
                           asp-controller="Librarian" asp-action="Intercom">
                        <i class="bi bi-telephone"></i> Intercom
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link sidebar-link"
                           asp-controller="Librarian" asp-action="SessionManagement">
                        <i class="bi bi-stopwatch"></i> Sessions
                    </a>
                </li>
            </ul>
        <div class="px-3 py-3 border-top border-secondary">
            <a href="/Account/Logout" class="text-danger text-decoration-none" style="font-size:13px;">
                <i class="bi bi-box-arrow-left me-2"></i>Logout
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="flex-grow-1 d-flex flex-column" style="background:#f4f6f9;">
        <div class="d-flex align-items-center justify-content-between px-4 py-3" style="background:#fff;border-bottom:1px solid #e2e8f0;">
            <h6 class="mb-0 fw-semibold text-dark">@ViewData["Title"]</h6>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-info-subtle text-info">Librarian</span>
                    <!--  <span style="font-size:13px;color:#6c757d;">@(ViewBag.User?.FullName)</span>-->
            </div>
        </div>

        <div class="px-4 pt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script src="~/js/site.js"></script>
<script>
    // SignalR — join librarian group & receive real-time notifications
    const connection = new signalR.HubConnectionBuilder().withUrl("/notificationHub").build();
    connection.start().then(() => {
        connection.invoke("JoinLibrarianGroup").catch(console.error);
    }).catch(console.error);

    connection.on("NewBookRequest", data => {
        showLibrarianPopup(data.memberName, data.message, data.requestId);
        updateNotifBadge();
    });

    function showLibrarianPopup(name, msg, reqId) {
        const c = document.getElementById("notif-container");
        const d = document.createElement("div");
        d.className = "alert alert-info alert-dismissible fade show shadow";
        d.style.cssText = "border-left:4px solid #0dcaf0;font-size:13px;";
        d.innerHTML = `
            <strong><i class="bi bi-bell-fill me-1"></i>New Book Request</strong><br/>
            <span>${msg}</span><br/>
            <a href="/Librarian/Requests" class="btn btn-sm btn-outline-info mt-2">View Request</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        c.appendChild(d);
        setTimeout(() => { if(d.parentNode) d.remove(); }, 10000);
    }

    function updateNotifBadge() {
        fetch('/Librarian/GetNotifications')
            .then(r => r.json())
            .then(data => {
                const badge = document.getElementById('notif-badge');
                if (data.length > 0) {
                    badge.textContent = data.length;
                    badge.style.display = 'inline';
                } else {
                    badge.style.display = 'none';
                }
            }).catch(() => {});
    }

    // Poll every 30s for badge count
    updateNotifBadge();
    setInterval(updateNotifBadge, 30000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
