<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MoDLibrary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body style="background:#f0f4f8;">

    <div id="remark-container" style="position:fixed;top:20px;right:20px;z-index:9999;width:360px;"></div>

    <!-- Announcements -->
    @{
        try
        {
            var config = Context.RequestServices.GetService<IConfiguration>();
            var dbHelper = new MoDLibrary.DAL.DatabaseHelper(config!);
            var announcements = dbHelper.GetActiveAnnouncements();
            foreach (var ann in announcements)
            {
                <div class="alert alert-info alert-dismissible fade show mb-0 rounded-0"
                     role="alert" style="font-size:13px;">
                    <div class="container-fluid">
                        <i class="bi bi-megaphone me-2"></i>
                        <strong>@ann.Title</strong> — @ann.Message
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                </div>
            }
        }
        catch { }
    }

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg" style="background:#0d1b2a;border-bottom:3px solid #f59e0b;">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Member" asp-action="Index">
                <i class="bi bi-book-half text-warning fs-5"></i>
                <span class="text-white fw-bold" style="font-size:16px;">MoDLibrary</span>
                <span class="text-secondary" style="font-size:11px;">| Ministry of Defence</span>
            </a>

            <div class="d-flex align-items-center gap-2 flex-wrap">

                <a asp-controller="Member" asp-action="Index"
                   class="btn btn-sm @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "btn-warning text-dark" : "btn-outline-light")">
                    <i class="bi bi-journals me-1"></i>Catalog
                </a>

                    @{
                        var sessionUser = Context.Session.GetString("User");
                        var isLoggedIn = sessionUser != null;
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    }

                <a asp-controller="Member" asp-action="EBooks"
                   class="btn btn-sm @(ViewContext.RouteData.Values["action"]?.ToString()=="EBooks"?"btn-warning text-dark":"btn-outline-light")">
                    <i class="bi bi-file-earmark-pdf me-1"></i>E-Books
                    @if (!isLoggedIn)
                    {
                        <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i>
                    }
                </a>

                <a asp-controller="Member" asp-action="Subscriptions"
                   class="btn btn-sm @(ViewContext.RouteData.Values["action"]?.ToString()=="Subscriptions"?"btn-warning text-dark":"btn-outline-light")">
                    <i class="bi bi-globe me-1"></i>Subscriptions
                    @if (!isLoggedIn)
                    {
                        <i class="bi bi-lock-fill ms-1" style="font-size:10px;"></i>
                    }
                </a>

                <a asp-controller="Member" asp-action="SuggestBook"
                   class="btn btn-sm btn-outline-light">
                    <i class="bi bi-lightbulb me-1"></i>Suggest
                </a>

                <a asp-controller="Member" asp-action="MySuggestions"
                   class="btn btn-sm btn-outline-light">
                    <i class="bi bi-list-check me-1"></i>My Suggestions
                </a>

                @if (isLoggedIn)
                {
                    <span class="badge bg-success-subtle text-success">Member</span>
                    <a href="/Account/Logout" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-box-arrow-left"></i> Logout
                    </a>
                }
                <!--else
                {
                    <a asp-controller="Account" asp-action="MemberLogin"
                       class="btn btn-sm btn-warning text-dark fw-semibold">
                        <i class="bi bi-person me-1"></i>Member Login
                    </a>
                }-->

            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
    <footer style="background: #0d1b2a; border-top:2px solid #f59e0b"; padding:12px 24px; margin-top:40px;">
        <div class="d-flex align-items-center justify-content-between">
        <small class="text-secondary">
            MoDLibrary - Ministry of Defence
        </small>

        <a asp-controller="Account" asp-action="Login"
               class="text-secondary text-decoration-none" style="font-size:12px">
              
            <i class="bi bi-person-badge me-1"></i>Staff Login
        </a>
        </div>

    </footer>"

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>