@model MoDLibrary.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — MoDLibrary</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body style="background:#f0f4f8;min-height:100vh;display:flex;align-items:center;justify-content:center;">

    <div class="container" style="max-width:440px;">

        <!-- Logo -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:64px;height:64px;background:rgba(13,148,136,.15);border:2px solid #0d9488;">
                <i class="bi bi-book-half fs-3" style="color:#0d9488;"></i>
            </div>
            <h4 class="fw-bold mb-0" style="color:#1e3a5f;">MoD-Library Management System</h4>
        </div>

        <!-- Login Card -->
        <div class="card shadow-sm border-0" style="border-radius:16px;border:1.5px solid #cbd5e1 !important;">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-1 text-dark">Welcome back</h5>
                <p class="text-muted mb-4" style="font-size:13px;">Sign in to access your portal</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2" style="font-size:13px;">
                        <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
                    </div>
                }

                <!-- Form with border -->
                <div style="border:1.5px solid #cbd5e1;border-radius:12px;padding:1.25rem;">
                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-medium" style="font-size:13px;">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-person text-muted"></i>
                                </span>
                                <input asp-for="Username" class="form-control border-start-0 ps-0"
                                       placeholder="Enter your username" autocomplete="username" required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium" style="font-size:13px;">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" type="password" class="form-control border-start-0 ps-0"
                                       placeholder="Enter your password" autocomplete="current-password" required />
                            </div>
                        </div>
                        <button type="submit" class="btn w-100 fw-semibold py-2"
                                style="background:#1e3a5f;color:#fff;border:none;border-radius:8px;">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                    </form>
                </div>

                <!-- Divider -->
                <div class="d-flex align-items-center gap-2 my-3">
                    <hr class="flex-grow-1 m-0" />
                    <span class="text-muted" style="font-size:12px;">OR</span>
                    <hr class="flex-grow-1 m-0" />
                </div>

                <!-- Continue as Member Button -->
                <a asp-controller="Account" asp-action="ContinueAsMember"
                   class="btn w-100 fw-semibold py-2"
                   style="background:#1e3a5f;color:#fff;border:none;border-radius:8px;">
                    <i class="bi bi-person-circle me-2"></i>Continue as Member
                </a>
                <p class="text-muted text-center mt-2 mb-0" style="font-size:11px;">
                    Library members can browse and request books without logging in
                </p>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>