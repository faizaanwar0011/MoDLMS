@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Member Login — MoDLibrary</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
            body {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, #eaf2fb 0%, #dce9f9 50%, #c9dcf5 100%);
                font-family: Arial, sans-serif;
            }

            .login-card {
                width: 100%;
                max-width: 420px;
                background: rgba(255, 255, 255, 0.75);
                backdrop-filter: blur(12px);
                border-radius: 18px;
                border: 1px solid rgba(255,255,255,0.4);
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                padding: 24px;
            }

            .icon-circle {
                width: 70px;
                height: 70px;
                background: rgba(251, 191, 36, 0.15);
                border: 2px solid #fbbf24;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: auto;
            }

            .form-control:focus {
                box-shadow: none;
                border-color: #fbbf24;
            }

            /* ✅ Custom Login Button */
            .login-btn {
                background: #f59e0b; /* rich gold (clean + professional) */
                color: #ffffff;
                border: none;
                transition: all 0.25s ease;
            }

                .login-btn:hover {
                    background: #d97706; /* deeper gold on hover */
                    color: #ffffff;
                    transform: translateY(-1px);
                    box-shadow: 0 8px 18px rgba(217, 119, 6, 0.35);
                }
    </style>
</head>

<body>

    <div class="login-card">

        <!-- Icon -->
        <div class="text-center mb-3">
            <div class="icon-circle mb-3">
                <i class="bi bi-person-circle fs-2 text-warning"></i>
            </div>

            <h4 class="fw-bold mb-1">Member Login</h4>
            <p class="text-muted" style="font-size:13px;">
                Login to access E-Books & Subscriptions
            </p>
        </div>

        <!-- Error -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" style="font-size:13px;">
                <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
            </div>
        }

        <!-- Form -->
        <form asp-action="MemberLogin" method="post">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control"
                       placeholder="Enter username" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control"
                       placeholder="Enter password" required />
            </div>

            <button type="submit" class="btn login-btn w-100 py-2 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </button>
        </form>

        <hr class="my-3" />

        <a asp-controller="Member" asp-action="Index"
               class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-left me-2"></i>Back to Catalog
        </a>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>