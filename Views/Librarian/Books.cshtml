@model List<MoDLibrary.Models.Book>
@{
    ViewData["Title"] = "All Books";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Book Catalog</h5>
        <small class="text-muted">@Model.Count(b => b.IsActive) active books</small>
    </div>
    <a asp-action="AddBook" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add Book
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:12px;">
    <div class="card-header bg-white border-bottom px-4 py-3">
        <input type="text" id="bFilter" class="form-control" style="max-width:320px;"
               placeholder="Filter books…" />
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="libBooksTable">
                <thead style="background:#f8f9fa;">
                    <tr>
                        <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book No.</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Title / Author</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Category</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Shelf Location</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Copies</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Availability</th>
                        <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Where(x => x.IsActive))
                    {
                        <tr>
                            <td class="px-4">
                                <span class="badge bg-light text-dark border" style="font-family:monospace;">@b.BookNumber</span>
                            </td>
                            <td>
                                <div class="fw-medium" style="font-size:14px;">@b.Title</div>
                                <div class="text-muted" style="font-size:12px;">@b.Author</div>
                            </td>
                            <td>
                                <div class="fw-medium" style="font-size:14px;">@b.Category</div>
                                
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info">
                                    <i class="bi bi-geo-alt me-1"></i>@b.ShelfLocation
                                </span>
                            </td>

                            <td style="font-size:13px;">
                                <span class="text-success fw-medium">@b.AvailableCopies</span>
                                <span class="text-muted"> / @b.TotalCopies</span>
                            </td>
                            <td>
                                @if (b.AvailableCopies > 0)
                                { <span class="badge bg-success-subtle text-success">Available</span> }
                                else
                                { <span class="badge bg-danger-subtle text-danger">All Issued</span> }
                            </td>
                            <td>
                                <a asp-action="EditBook" asp-route-id="@b.BookId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('bFilter').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#libBooksTable tbody tr').forEach(r => {
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>
}
