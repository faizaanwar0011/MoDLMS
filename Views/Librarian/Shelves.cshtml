@model List<MoDLibrary.Models.Shelf>
@{
    ViewData["Title"] = "Shelves";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="mb-4">
    <h5 class="fw-semibold mb-0">Library Shelves</h5>
    <small class="text-muted">Rack and row layout of the library</small>
</div>

@foreach (var rack in Model.GroupBy(s => s.RackLetter).OrderBy(g => g.Key))
{
    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px;">
        <div class="card-header bg-white border-bottom py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width:36px;height:36px;background:#e7f1ff;color:#0d6efd;font-size:16px;">
                    @rack.Key
                </div>
                <div>
                    <div class="fw-semibold" style="font-size:14px;">
                        Rack @rack.Key — @rack.First().CategoryName
                    </div>
                    <div class="text-muted" style="font-size:12px;">
                        @rack.Count() rows | Code: @rack.First().CategoryCode
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body px-4 py-3">
            <div class="d-flex gap-3 flex-wrap">
                @foreach (var shelf in rack.OrderBy(s => s.RowNumber))
                {
                    <div class="p-3 text-center"
                         style="background:#f8fafc;border-radius:8px;
                                        border:1px solid #e2e8f0;min-width:100px;">
                        <div class="fw-bold text-primary" style="font-size:18px;">@shelf.ShelfCode</div>
                        <div class="text-muted" style="font-size:11px;">Row @shelf.RowNumber</div>
                        <div class="mt-1">
                            @if (shelf.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success" style="font-size:9px;">Active</span>
                            }
                            else
                            {

                                <span class="badge bg-secondary-subtle text-secondary" style="font-size:9px;">Inactive</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
