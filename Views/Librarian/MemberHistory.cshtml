@model List<MoDLibrary.Models.MemberHistoryRecord>
@{
    ViewData["Title"] = "Member History";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    // Admin k liye: Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h5 class="fw-semibold mb-1">Member History</h5>
    <small class="text-muted">Search complete borrowing history by Name</small>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-4">
        <form asp-action="MemberHistory" method="get">
            <div class="d-flex gap-3">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-credit-card-2-front text-muted"></i>
                        </span>
                        <input type="text" name="search" value="@ViewBag.Name"
                               class="form-control"
                               placeholder="Enter Name or CNIC" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.Name != "")
{
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-person-x" style="font-size:48px;opacity:.3;"></i>
            <p class="mt-3">No history found.</p>
        </div>
    }
    else
    {
        <!-- Member Info -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius:12px;border-left:4px solid #0d6efd !important;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:44px;height:44px;background:#e7f1ff;font-size:16px;font-weight:700;color:#0d6efd;">
                        @Model.First().MemberName.Substring(0,1).ToUpper()
                    </div>
                    <div>
                        <div class="fw-bold" style="font-size:15px;">@Model.First().MemberName</div>
                        <div class="text-muted" style="font-size:12px;">
                            CNIC: @Model.First().CNIC &nbsp;|&nbsp;
                            Service No: @Model.First().ServiceNo &nbsp;|&nbsp;
                            Total Books: @Model.Count
                        </div>
                    </div>
                    <div class="ms-auto text-end">
                        <div class="text-danger fw-bold" style="font-size:14px;">
                            Total Fines: Rs. @Model.Sum(m => m.FineAmount).ToString("N0")
                        </div>
                        <div class="text-muted" style="font-size:12px;">
                            Returned: @Model.Count(m => m.IsReturned) /
                            Pending: @Model.Count(m => !m.IsReturned)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Table -->
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background:#f8f9fa;">
                            <tr>
                                <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                                <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Issue Date</th>
                                <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Due Date</th>
                                <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Return Date</th>
                                <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Fine</th>
                                <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="fw-medium" style="font-size:13px;">@h.BookTitle</div>
                                        <div class="text-muted" style="font-size:11px;">@h.BookNumber</div>
                                    </td>
                                    <td style="font-size:12px;">@h.IssueDate.ToString("dd MMM yyyy")</td>
                                    <td style="font-size:12px;">@h.DueDate.ToString("dd MMM yyyy")</td>
                                    <td style="font-size:12px;">
                                        @(h.ReturnDate.HasValue ? h.ReturnDate.Value.ToString("dd MMM yyyy") : "—")
                                    </td>
                                    <td>
                                        @if (h.FineAmount > 0)
                                        {
                                            <span class="fw-bold text-danger">Rs. @h.FineAmount.ToString("N0")</span>
                                            @if (h.FinePaid)
                                            {
                                                <span class="badge bg-success-subtle text-success ms-1">Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger ms-1">Unpaid</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-success">None</span>
                                        }
                                    </td>
                                    <td>
                                        @if (h.IsReturned)
                                        {
                                            <span class="badge bg-success-subtle text-success">Returned</span>
                                        }
                                        else if (h.DueDate < DateTime.Now)
                                        {
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary-subtle text-primary">Active</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
