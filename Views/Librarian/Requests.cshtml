@model List<MoDLibrary.Models.BookRequest>
@{
    ViewData["Title"] = "Book Requests";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    var pending   = Model.Where(r => r.Status == "Pending").ToList();
    var approved  = Model.Where(r => r.Status == "Approved").ToList();
    var collected = Model.Where(r => r.Status == "Collected").ToList();
    var rejected  = Model.Where(r => r.Status == "Rejected").ToList();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Book Requests</h5>
        <small class="text-muted">Review and respond to member requests</small>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-warning text-dark py-2 px-3">Pending: @pending.Count</span>
        <span class="badge bg-success py-2 px-3">Approved: @approved.Count</span>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#pendingTab">
        Pending <span class="badge bg-warning text-dark ms-1">@pending.Count</span>
    </a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#approvedTab">Approved (@approved.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#collectedTab">Collected (@collected.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rejectedTab">Rejected (@rejected.Count)</a></li>
</ul>

<div class="tab-content">
    @foreach (var (tabId, list) in new[] {
        ("pendingTab",   pending),
        ("approvedTab",  approved),
        ("collectedTab", collected),
        ("rejectedTab",  rejected)
    })
    {
        <div class="tab-pane fade @(tabId=="pendingTab"?"show active":"")" id="@tabId">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead style="background:#f8f9fa;">
                                <tr>
                                    <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">#</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Member Info</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Wing / Section</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Shelf</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Status</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!list.Any())
                                {
                                    <tr><td colspan="8" class="text-center py-4 text-muted">No requests in this category.</td></tr>
                                }
                                @foreach (var r in list)
                                {
                                    <tr>
                                        <td class="px-4"><small class="text-muted">#@r.RequestId</small></td>
                                        <td>
                                            <div class="fw-medium" style="font-size:13px;">@r.MemberName</div>
                                            <div class="text-muted" style="font-size:11px;">CNIC: @r.CNIC</div>
                                            <div class="text-muted" style="font-size:11px;">Svc No: @r.ServiceNo</div>
                                        </td>
                                        <td style="font-size:12px;">
                                            <span class="badge bg-light text-dark border">@r.WingName</span>
                                            <div class="text-muted mt-1">@r.SectionName</div>
                                        </td>
                                        <td>
                                            <div class="fw-medium" style="font-size:13px;">@r.BookTitle</div>
                                            <div class="text-muted" style="font-size:11px;">@r.BookNumber</div>
                                        </td>
                                        <td>
                                            <span class="badge bg-info-subtle text-info" style="font-size:11px;">
                                                <i class="bi bi-geo-alt me-1"></i>@r.ShelfLocation
                                            </span>
                                        </td>
                                        <td style="font-size:12px;color:#6c757d;">@r.RequestDate.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            @switch (r.Status)
                                            {
                                                case "Pending":
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                    break;
                                                case "Approved":
                                                    <span class="badge bg-success">Approved</span>
                                                    break;
                                                case "Rejected":
                                                    <span class="badge bg-danger">Rejected</span>
                                                    break;
                                                case "Collected":
                                                    <span class="badge bg-secondary">Collected</span>
                                                    break;
                                            }
                                            @if (!string.IsNullOrEmpty(r.Remark))
                                            {
                                                <div class="text-muted mt-1" style="font-size:11px;max-width:140px;" title="@r.Remark">
                                                    "@r.Remark.Substring(0, Math.Min(40, r.Remark.Length))@(r.Remark.Length > 40 ? "…" : "")"
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column gap-1">
                                                @if (r.Status == "Pending" || r.Status == "Approved")
                                                {
                                                    <!-- Send Remark Button -->
                                                    <button class="btn btn-sm btn-outline-primary"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#remarkModal"
                                                            onclick="setRemarkModal(@r.RequestId, '@r.Status')">
                                                        <i class="bi bi-chat-text me-1"></i>Send Remark
                                                    </button>
                                                }
                                                @if (r.Status == "Approved")
                                                {
                                                    <!-- Issue Book Button -->
                                                    <form asp-action="IssueBook" method="post"
                                                          onsubmit="return confirm('Mark this book as physically issued to @r.MemberName?')">
                                                        <input type="hidden" name="requestId" value="@r.RequestId" />
                                                        <button class="btn btn-sm btn-success w-100">
                                                            <i class="bi bi-bookmark-check me-1"></i>Mark Issued
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Remark Modal -->
<div class="modal fade" id="remarkModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-chat-text me-2 text-primary"></i>Send Remark to Member
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SendRemark" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="RequestId" id="modalRequestId" />

                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Update Status</label>
                        <select name="Status" id="modalStatus" class="form-select">
                            <option value="Approved">Approved — Book is available, come collect</option>
                            <option value="Rejected">Rejected — Book unavailable / request denied</option>
                            <option value="Pending">Pending — Still being processed</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Remark / Message</label>
                        <textarea name="Remark" id="modalRemark" class="form-control" rows="3"
                                  placeholder="e.g. Book is available. Please come and collect it from the library during office hours."
                                  required></textarea>
                    </div>

                    <!-- Quick templates -->
                    <div>
                        <div class="text-muted mb-2" style="font-size:12px;">Quick Templates:</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-sm btn-outline-success"
                                    onclick="useTemplate('Approved','Book is available. Please come and collect it from the library during working hours.')">
                                Available — Come collect
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-warning"
                                    onclick="useTemplate('Pending','Your request is under review. We will notify you shortly.')">
                                Under review
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="useTemplate('Rejected','Sorry, this book is currently not available. Please try again later.')">
                                Not available
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-send me-2"></i>Send Remark
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function setRemarkModal(requestId, currentStatus) {
        document.getElementById('modalRequestId').value = requestId;
        document.getElementById('modalStatus').value = currentStatus === 'Pending' ? 'Approved' : currentStatus;
    }

    function useTemplate(status, remark) {
        document.getElementById('modalStatus').value = status;
        document.getElementById('modalRemark').value = remark;
    }
</script>
}
