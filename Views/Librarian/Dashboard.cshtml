@model MoDLibrary.Models.LibrarianDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #0d6efd!important;border-radius:12px;">
            <div class="card-body">
                <div class="text-muted mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Total Books</div>
                <div class="fw-bold" style="font-size:28px;">@Model.Stats.TotalBooks</div>
                <a asp-action="Books" class="text-decoration-none" style="font-size:12px;">View catalog →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #198754!important;border-radius:12px;">
            <div class="card-body">
                <div class="text-muted mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Currently Issued</div>
                <div class="fw-bold" style="font-size:28px;">@Model.Stats.BooksIssued</div>
                <a asp-action="IssuedBooks" class="text-decoration-none" style="font-size:12px;">View all →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #ffc107!important;border-radius:12px;">
            <div class="card-body">
                <div class="text-muted mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Pending Requests</div>
                <div class="fw-bold text-warning" style="font-size:28px;">@Model.Stats.PendingRequests</div>
                <a asp-action="Requests" class="text-decoration-none" style="font-size:12px;">Handle now →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #dc3545!important;border-radius:12px;">
            <div class="card-body">
                <div class="text-muted mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Overdue Books</div>
                <div class="fw-bold text-danger" style="font-size:28px;">@Model.Stats.OverdueBooks</div>
                <a asp-action="IssuedBooks" class="text-decoration-none" style="font-size:12px;">Check overdue →</a>
            </div>
        </div>
    </div>
</div>

<!-- Pending Requests + Overdue Books -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
            <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3">
                <span class="fw-semibold" style="font-size:14px;">
                    <i class="bi bi-inbox me-2 text-warning"></i>Pending Requests
                    @if (Model.Stats.PendingRequests > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@Model.Stats.PendingRequests</span>
                    }
                </span>
                <a asp-action="Requests" class="text-decoration-none" style="font-size:12px;">View all →</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.PendingRequests.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-check-circle text-success fs-3 d-block mb-2"></i>
                        <span style="font-size:13px;">No pending requests!</span>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var r in Model.PendingRequests)
                        {
                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex align-items-start justify-content-between gap-2">
                                    <div>
                                        <div class="fw-medium" style="font-size:13px;">@r.MemberName</div>
                                        <div class="text-muted" style="font-size:12px;">
                                            <i class="bi bi-book me-1"></i>@r.BookTitle
                                            <span class="ms-2 badge bg-light text-dark border" style="font-size:11px;font-family:monospace;">@r.BookNumber</span>
                                        </div>
                                        <div class="text-muted" style="font-size:11px;">
                                            <i class="bi bi-geo-alt me-1"></i>@r.ShelfLocation
                                            &nbsp;|&nbsp;
                                            <i class="bi bi-diagram-3 me-1"></i>@r.WingName — @r.SectionName
                                        </div>
                                        <div class="text-muted" style="font-size:11px;">@r.RequestDate.ToString("dd MMM yyyy — hh:mm tt")</div>
                                    </div>
                                    <a asp-controller="Librarian" asp-action="Requests"
                                       class="btn btn-sm btn-warning text-dark flex-shrink-0">
                                        <i class="bi bi-arrow-right me-1"></i>Handle
                                    </a>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
            <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3">
                <span class="fw-semibold" style="font-size:14px;">
                    <i class="bi bi-exclamation-triangle me-2 text-danger"></i>Overdue Books
                </span>
                <a asp-action="IssuedBooks" class="text-decoration-none" style="font-size:12px;">View all →</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.OverdueBooks.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-check-circle text-success fs-3 d-block mb-2"></i>
                        <span style="font-size:13px;">No overdue books!</span>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var ob in Model.OverdueBooks)
                        {
                            <li class="list-group-item px-4 py-3" style="background:#fff9f9;">
                                <div class="fw-medium" style="font-size:13px;">@ob.MemberName</div>
                                <div class="text-muted" style="font-size:12px;">@ob.BookTitle</div>
                                <div class="d-flex align-items-center justify-content-between mt-1">
                                    <span class="text-danger" style="font-size:11px;">
                                        @ob.DaysLate day(s) late
                                    </span>
                                    <span class="text-danger fw-bold" style="font-size:13px;">
                                        Rs. @ob.FineAmount.ToString("N0")
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>