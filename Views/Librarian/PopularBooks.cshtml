@model List<MoDLibrary.Models.PopularBook>
@{
    ViewData["Title"] = "Popular Books";
     Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Most Popular Books</h5>
        <small class="text-muted">Top 10 most requested books in the library</small>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-trophy" style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">No data yet — books will appear here once requests are made.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Rank</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Author</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Category</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Shelf</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Total Requests</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Avg Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var b = Model[i];
                            <tr>
                                <td class="px-4">
                                    @if (i == 0)
                                    {
                                        <span class="badge bg-warning text-dark" style="font-size:13px;">🥇 1</span>
                                    }
                                    else if (i == 1)
                                    {
                                        <span class="badge bg-secondary" style="font-size:13px;">🥈 2</span>
                                    }
                                    else if (i == 2)
                                    {
                                        <span class="badge bg-danger" style="font-size:13px;">🥉 3</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fw-medium" style="font-size:14px;">@(i + 1)</span>
                                    }
                                </td>
                                <td>
                                    <div class="fw-medium" style="font-size:14px;">@b.Title</div>
                                    <div class="text-muted" style="font-size:11px;">@b.BookNumber</div>
                                </td>
                                <td style="font-size:13px;">@b.Author</td>
                                <td>
                                    <span class="badge bg-light text-secondary border" style="font-size:11px;">
                                        @b.Category
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info" style="font-size:11px;">
                                        <i class="bi bi-geo-alt me-1"></i>@b.ShelfLocation
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="background:#e7f1ff;border-radius:4px;height:8px;width:80px;">
                                            <div style="background:#0d6efd;border-radius:4px;height:8px;
                                                                width:@(Model.Max(x => x.TotalRequests) > 0 ? (b.TotalRequests * 100 / Model.Max(x => x.TotalRequests)) : 0)%;">
                                            </div>
                                        </div>
                                        <span class="fw-bold text-primary">@b.TotalRequests</span>
                                    </div>
                                </td>
                                <td>
                                    @if (b.AvgRating > 0)
                                    {
                                        <span class="text-warning fw-bold">
                                            ⭐ @b.AvgRating.ToString("F1")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size:12px;">No ratings yet</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
