@model List<MoDLibrary.Models.Book>
@{
    ViewData["Title"] = "Search Books";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
}

<div class="mb-4">
    <h5 class="fw-semibold mb-1">Search Books</h5>
    <small class="text-muted">Find a book by title, author name, or book number</small>
</div>

<!-- Search bar -->
<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-4">
        <form asp-action="Search" method="get">
            <div class="d-flex gap-3">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="q" value="@ViewBag.Query" class="form-control border-start-0 ps-0"
                               placeholder="Search by book title, author name, or book number…"
                               autofocus style="font-size:15px;" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search me-2"></i>Search
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Query?.ToString()))
                {
                    <a asp-action="Search" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>
    </div>
</div>

@if (ViewBag.Query != null)
{
    <div class="mb-3 d-flex align-items-center gap-2">
        <span class="text-muted" style="font-size:13px;">
            @Model.Count result(s) for "<strong>@ViewBag.Query</strong>"
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5" style="border-radius:12px;">
            <i class="bi bi-search text-muted" style="font-size:48px;"></i>
            <p class="text-muted mt-3 mb-0">No books found matching your search.</p>
            <small class="text-muted">Try a different title, author name, or book number.</small>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var b in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100" style="border-radius:12px;@(b.AvailableCopies > 0 ? "border-left:3px solid #198754!important;" : "border-left:3px solid #dc3545!important;")">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-light text-dark border" style="font-family:monospace;font-size:12px;">@b.BookNumber</span>
                                @if (b.AvailableCopies > 0)
                                {
                                    <span class="badge bg-success-subtle text-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Not Available</span>
                                }
                            </div>
                            <h6 class="fw-semibold mb-1" style="font-size:15px;">@b.Title</h6>
                            <div class="text-muted mb-3" style="font-size:13px;">by @b.Author</div>

                            <!-- Shelf Location Highlight -->
                            <div class="d-flex align-items-center gap-2 p-2 mb-3"
                                 style="background:#e7f5ff;border-radius:8px;border:1px solid #bee3f8;">
                                <i class="bi bi-geo-alt-fill text-primary"></i>
                                <div>
                                    <div style="font-size:10px;color:#0d6efd;text-transform:uppercase;letter-spacing:.5px;">Shelf Location</div>
                                    <div class="fw-bold text-primary" style="font-size:15px;">@b.ShelfLocation</div>
                                </div>
                            </div>

                            <div class="row g-2" style="font-size:12px;">
                                <div class="col-6">
                                    <span class="text-muted">Category:</span>
                                    <span class="fw-medium ms-1">@(b.Category ?? "—")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Publisher:</span>
                                    <span class="fw-medium ms-1">@(b.Publisher ?? "—")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Year:</span>
                                    <span class="fw-medium ms-1">@(b.PublishedYear?.ToString() ?? "—")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Copies:</span>
                                    <span class="fw-medium ms-1 text-success">@b.AvailableCopies</span>
                                    <span class="text-muted">/ @b.TotalCopies</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-book-open" style="font-size:56px;opacity:.3;"></i>
        <p class="mt-3">Enter a search term above to find books and their shelf locations.</p>
    </div>
}
