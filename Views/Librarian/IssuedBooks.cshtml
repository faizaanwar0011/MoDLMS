@model List<MoDLibrary.Models.IssuedBook>
@{
    ViewData["Title"] = "Issued Books";
    Layout = "~/Views/Shared/_LibrarianLayout.cshtml";
    var active  = Model.Where(x => !x.IsReturned && x.BookStatus == "Active").ToList();
    var overdue = Model.Where(x => !x.IsReturned && x.BookStatus == "Overdue").ToList();
    var returned= Model.Where(x => x.IsReturned).ToList();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 class="fw-semibold mb-0">Issued Books</h5>
        <small class="text-muted">Manage active issues and process returns</small>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-success py-2 px-3">Active: @active.Count</span>
        <span class="badge bg-danger py-2 px-3">Overdue: @overdue.Count</span>
        <span class="badge bg-secondary py-2 px-3">Returned: @returned.Count</span>
    </div>
</div>

@if (overdue.Any())
{
    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3 fs-5"></i>
        <div>
            <strong>@overdue.Count book(s) are overdue.</strong>
            A fine of Rs. 50 per day is being applied. Please process returns promptly.
        </div>
    </div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#allIssued">All (@Model.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#activeIssued">Active (@active.Count)</a></li>
    <li class="nav-item"><a class="nav-link text-danger fw-medium" data-bs-toggle="tab" href="#overdueIssued">
        Overdue (@overdue.Count)
    </a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#returnedIssued">Returned (@returned.Count)</a></li>
</ul>

<div class="tab-content">
    @foreach (var (tabId, list) in new[] {
        ("allIssued",      Model.ToList()),
        ("activeIssued",   active),
        ("overdueIssued",  overdue),
        ("returnedIssued", returned)
    })
    {
        <div class="tab-pane fade @(tabId=="allIssued"?"show active":"")" id="@tabId">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead style="background:#f8f9fa;">
                                <tr>
                                    <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Member</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">CNIC / Svc No</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Wing / Section</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Issue Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Due Date</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Status / Fine</th>
                                    <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!list.Any())
                                {
                                    <tr><td colspan="8" class="text-center py-4 text-muted">No records found.</td></tr>
                                }
                                @foreach (var ib in list)
                                {
                                    <tr class="@(ib.BookStatus=="Overdue"?"table-danger bg-opacity-25":"")">
                                        <td class="px-4">
                                            <div class="fw-medium" style="font-size:13px;">@ib.MemberName</div>
                                        </td>
                                        <td style="font-size:12px;">
                                            <div>@ib.CNIC</div>
                                            <div class="text-muted">@ib.ServiceNo</div>
                                        </td>
                                        <td style="font-size:12px;">
                                            <span class="badge bg-light text-dark border">@ib.WingName</span>
                                            <div class="text-muted mt-1">@ib.SectionName</div>
                                        </td>
                                        <td>
                                            <div class="fw-medium" style="font-size:13px;">@ib.BookTitle</div>
                                            <div class="text-muted" style="font-size:11px;">@ib.BookNumber</div>
                                        </td>
                                        <td style="font-size:12px;">@ib.IssueDate.ToString("dd MMM yyyy")</td>
                                        <td style="font-size:12px;">
                                            <span class="@(ib.BookStatus=="Overdue"?"text-danger fw-bold":"")">
                                                @ib.DueDate.ToString("dd MMM yyyy")
                                            </span>
                                            @if (ib.BookStatus == "Overdue")
                                            {
                                                var daysLate = (DateTime.Now - ib.DueDate).Days;
                                                <div class="text-danger" style="font-size:11px;">@daysLate day(s) late</div>
                                            }
                                        </td>
                                        <td>
                                            @switch (ib.BookStatus)
                                            {
                                                case "Active":
                                                    <span class="badge bg-success-subtle text-success">Active</span>
                                                    break;
                                                case "Overdue":
                                                    <span class="badge bg-danger">Overdue</span>
                                                    <div class="text-danger fw-bold mt-1" style="font-size:13px;">
                                                        Rs. @ib.PendingFine.ToString("N0")
                                                    </div>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary-subtle text-secondary">Returned</span>
                                                    @if (ib.ReturnDate.HasValue)
                                                    {
                                                        <div class="text-muted" style="font-size:11px;">@ib.ReturnDate.Value.ToString("dd MMM yyyy")</div>
                                                    }
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            @if (!ib.IsReturned)
                                            {
                                                <form asp-action="ReturnBook" method="post"
                                                      onsubmit="return confirm('Process return for @ib.MemberName — @ib.BookTitle?')">
                                                    <input type="hidden" name="issuedId" value="@ib.IssuedId" />
                                                    <button class="btn btn-sm @(ib.BookStatus=="Overdue"?"btn-danger":"btn-outline-success")">
                                                        <i class="bi bi-arrow-return-left me-1"></i>Return
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted" style="font-size:12px;">Done</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
