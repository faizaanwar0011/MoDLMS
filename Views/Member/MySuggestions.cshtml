@model List<MoDLibrary.Models.BookSuggestion>
@{
    ViewData["Title"] = "My Suggestions";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">My Book Suggestions</h4>
    <p class="text-muted mb-0" style="font-size:14px;">
        Enter your CNIC to check the status of your suggestions
    </p>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-4">
        <form asp-action="MySuggestions" method="get">
            <div class="d-flex gap-3">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-credit-card-2-front text-muted"></i>
                        </span>
                        <input type="text" name="cnic" value="@ViewBag.CNIC"
                               class="form-control border-start-0 ps-1"
                               placeholder="Enter your CNIC — e.g. 42201-1234567-1"
                               maxlength="15" style="font-size:14px;" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search me-2"></i>Check Status
                </button>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.CNIC != "")
{
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-lightbulb text-muted" style="font-size:56px;opacity:.3;"></i>
            <p class="text-muted mt-3">No suggestions found for this CNIC.</p>
            <a asp-action="SuggestBook" class="btn btn-warning mt-2">
                <i class="bi bi-plus-circle me-2"></i>Suggest a Book
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var s in Model)
            {
                var borderColor = s.Status switch
                {
                                    "Available" => "#16a34a",
                                    "Ordered" => "#0d6efd",
                                    "UnderReview" => "#d97706",
                                    "Rejected" => "#dc2626",
                    _ => "#94a3b8"
                };
                <div class="card border-0 shadow-sm"
                     style="border-radius:12px;border-left:4px solid @borderColor !important;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
                            <div>
                                <div class="fw-bold" style="font-size:16px;">
                                    <i class="bi bi-book me-2 text-muted"></i>@s.BookTitle
                                </div>
                                @if (!string.IsNullOrEmpty(s.AuthorName))
                                {
                                    <div class="text-muted" style="font-size:13px;">
                                        by @s.AuthorName
                                    </div>
                                }
                            </div>
                            <div>
                                @switch (s.Status)
                                {
                                    case "Pending":
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2">
                                            <i class="bi bi-hourglass me-1"></i>Pending Review
                                        </span>
                                        break;
                                    case "UnderReview":
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                            <i class="bi bi-eye me-1"></i>Under Review
                                        </span>
                                        break;
                                    case "Ordered":
                                        <span class="badge bg-info-subtle text-info px-3 py-2">
                                            <i class="bi bi-truck me-1"></i>Ordered
                                        </span>
                                        break;
                                    case "Available":
                                        <span class="badge bg-success px-3 py-2">
                                            <i class="bi bi-check-circle me-1"></i>Available in Library!
                                        </span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-danger px-3 py-2">
                                            <i class="bi bi-x-circle me-1"></i>Not Approved
                                        </span>
                                        break;
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(s.Reason))
                        {
                            <div class="text-muted mb-3" style="font-size:13px;">
                                <i class="bi bi-chat-quote me-1"></i>@s.Reason
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(s.AdminRemark))
                        {
                            <div class="p-3 mb-3 rounded"
                                 style="background:#f0f9ff;border:1px solid #bae6fd;">
                                <div style="font-size:11px;color:#0369a1;text-transform:uppercase;
                                                            letter-spacing:.5px;margin-bottom:4px;">
                                    <i class="bi bi-chat-text me-1"></i>Library Response
                                </div>
                                <div class="fw-medium" style="font-size:14px;color:#0c4a6e;">
                                    "@s.AdminRemark"
                                </div>
                            </div>
                        }

                        @if (s.Status == "Available")
                        {
                            <div class="alert alert-success d-flex align-items-center gap-2 mb-3"
                                 style="font-size:13px;">
                                <i class="bi bi-check-circle-fill"></i>
                                <div>
                                    <strong>Great news! Your suggested book is now available.</strong>
                                    Visit the library to request it.
                                </div>
                            </div>
                            <a asp-action="Search" class="btn btn-success btn-sm">
                                <i class="bi bi-search me-1"></i>Search & Request This Book
                            </a>
                        }

                        <div class="mt-3 pt-2 border-top d-flex gap-3"
                             style="font-size:12px;color:#94a3b8;">
                            <span>
                                <i class="bi bi-calendar3 me-1"></i>
                                Suggested: @s.SuggestedAt.ToString("dd MMM yyyy")
                            </span>
                            @if (s.UpdatedAt.HasValue)
                            {
                                <span>
                                    <i class="bi bi-arrow-clockwise me-1"></i>
                                    Updated: @s.UpdatedAt.Value.ToString("dd MMM yyyy")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}