@{
    ViewData["Title"] = "Request Submitted";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm text-center" style="border-radius:16px;">
            <div class="card-body p-5">
                <!-- Success Icon -->
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4"
                     style="width:80px;height:80px;background:#d1e7dd;">
                    <i class="bi bi-check-lg text-success" style="font-size:40px;"></i>
                </div>

                <h4 class="fw-bold mb-2">Request Submitted!</h4>
                <p class="text-muted mb-1">Your book request has been sent to the librarian.</p>
                <div class="badge bg-light text-secondary border mb-4" style="font-size:13px;">
                    Request #@ViewBag.RequestId
                </div>

                <!-- What happens next -->
                <div class="card bg-light border-0 text-start mb-4" style="border-radius:10px;">
                    <div class="card-body p-4">
                        <div class="fw-semibold mb-3" style="font-size:14px;">
                            <i class="bi bi-list-check me-2 text-primary"></i>What happens next?
                        </div>
                        <div class="d-flex gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-primary text-white fw-bold"
                                 style="width:28px;height:28px;font-size:13px;">1</div>
                            <div>
                                <div class="fw-medium" style="font-size:13px;">Librarian Reviews</div>
                                <div class="text-muted" style="font-size:12px;">The librarian will check book availability and review your request.</div>
                            </div>
                        </div>
                        <div class="d-flex gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-primary text-white fw-bold"
                                 style="width:28px;height:28px;font-size:13px;">2</div>
                            <div>
                                <div class="fw-medium" style="font-size:13px;">You Receive a Notification</div>
                                <div class="text-muted" style="font-size:12px;">A real-time notification with a remark will appear in your browser.</div>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 bg-primary text-white fw-bold"
                                 style="width:28px;height:28px;font-size:13px;">3</div>
                            <div>
                                <div class="fw-medium" style="font-size:13px;">Collect the Book</div>
                                <div class="text-muted" style="font-size:12px;">Visit the library to physically collect the book. Loan period is 15 days. Fine of Rs. 50/day applies after deadline.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning d-flex align-items-center gap-2 text-start mb-4" style="font-size:13px;">
                    <i class="bi bi-bell-fill flex-shrink-0"></i>
                    <span>Keep this browser tab open to receive real-time notifications from the librarian.</span>
                </div>

                <a asp-action="Search" class="btn btn-primary px-5">
                    <i class="bi bi-search me-2"></i>Search More Books
                </a>
            </div>
        </div>
    </div>
</div>
