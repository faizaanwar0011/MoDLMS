@model List<MoDLibrary.Models.Book>
@{
    ViewData["Title"] = "Library Catalog";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";

    var categories = Model.Select(b => b.Category ?? "General")
                          .Distinct().OrderBy(c => c).ToList();
    var totalBooks     = Model.Count;
    var availableBooks = Model.Count(b => b.AvailableCopies > 0);
}

<!-- Page Header -->
<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Library Catalog</h4>
        <p class="text-muted mb-0" style="font-size:14px;">
            Browse all books — <span class="text-success fw-medium">@availableBooks available</span>
            out of <strong>@totalBooks</strong> total
        </p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <!-- Availability toggle -->
        <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
            <input class="form-check-input" type="checkbox" id="availableOnly" style="cursor:pointer;">
            <label class="form-check-label text-muted" for="availableOnly" style="font-size:13px;cursor:pointer;">
                Available only
            </label>
        </div>
    </div>
</div>

<!-- Search Bar -->
<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-3">
        <div class="input-group input-group-lg">
            <span class="input-group-text bg-white border-end-0 ps-3">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="liveSearch"
                   class="form-control border-start-0 ps-1"
                   placeholder="Type to search by title, author, or book number…"
                   autocomplete="off"
                   style="font-size:15px;" />
            <button class="btn btn-outline-secondary border-start-0" id="clearSearch" style="display:none;" type="button">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>
</div>

<!-- Category Filter Tabs -->
@if (categories.Count > 1)
{
    <div class="mb-4 d-flex flex-wrap gap-2" id="categoryFilters">
        <button class="btn btn-primary btn-sm category-btn active" data-cat="all">
            All <span class="badge bg-white text-primary ms-1">@totalBooks</span>
        </button>
        @foreach (var cat in categories)
        {
            var count = Model.Count(b => (b.Category ?? "General") == cat);
            <button class="btn btn-outline-secondary btn-sm category-btn" data-cat="@cat">
                @cat <span class="badge bg-secondary ms-1">@count</span>
            </button>
        }
    </div>
}

<!-- Results count -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <small class="text-muted" id="resultCount">Showing all @totalBooks books</small>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary active" id="viewGrid" title="Grid view">
            <i class="bi bi-grid-3x3-gap"></i>
        </button>
        <button class="btn btn-sm btn-outline-secondary" id="viewList" title="List view">
            <i class="bi bi-list-ul"></i>
        </button>
    </div>
</div>

<!-- No results message (hidden by default) -->
<div id="noResults" class="text-center py-5" style="display:none;">
    <i class="bi bi-journal-x text-muted" style="font-size:56px;opacity:.3;"></i>
    <p class="text-muted mt-3 mb-0 fw-medium">No books match your search.</p>
    <small class="text-muted">Try a different keyword or clear the filter.</small>
</div>

<!-- ── GRID VIEW ──────────────────────────────────────────────────────────── -->
<div id="gridView" class="row g-3">
    @foreach (var b in Model)
    {
        <div class="col-md-6 col-lg-4 book-item"
             data-title="@b.Title.ToLower()"
             data-author="@b.Author.ToLower()"
             data-bookno="@b.BookNumber.ToLower()"
             data-category="@(b.Category ?? "General")"
             data-available="@(b.AvailableCopies > 0 ? "yes" : "no")">
            <div class="card border-0 shadow-sm h-100 book-card" style="border-radius:12px;transition:transform .15s,box-shadow .15s;">
                <!-- Availability stripe -->
                <div style="height:4px;border-radius:12px 12px 0 0;background:@(b.AvailableCopies > 0 ? "#16a34a" : "#dc2626");"></div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-light text-dark border" style="font-family:monospace;font-size:11px;">
                            @b.BookNumber
                        </span>
                        @if (b.AvailableCopies > 0)
                        {
                            <span class="badge bg-success-subtle text-success" style="font-size:11px;">
                                <i class="bi bi-check-circle me-1"></i>Available
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger" style="font-size:11px;">
                                <i class="bi bi-hourglass me-1"></i>Unavailable
                            </span>
                        }
                    </div>

                    <h6 class="fw-semibold mb-1 mt-2" style="font-size:15px;line-height:1.4;">@b.Title</h6>
                    <div class="text-muted mb-3" style="font-size:13px;">
                        <i class="bi bi-person me-1"></i>@b.Author
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (!string.IsNullOrEmpty(b.Category))
                        {
                            <span class="badge bg-light text-secondary border" style="font-size:11px;">
                                <i class="bi bi-tag me-1"></i>@b.Category
                            </span>
                        }
                        @if (b.PublishedYear.HasValue)
                        {
                            <span class="badge bg-light text-secondary border" style="font-size:11px;">
                                <i class="bi bi-calendar3 me-1"></i>@b.PublishedYear
                            </span>
                        }
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-3"
                         style="font-size:12px;color:#6c757d;">
                        <span>
                            <i class="bi bi-copy me-1"></i>
                            <span class="@(b.AvailableCopies > 0 ? "text-success fw-medium" : "text-danger fw-medium")">
                                @b.AvailableCopies
                            </span> / @b.TotalCopies copies
                        </span>
                        @if (!string.IsNullOrEmpty(b.Publisher))
                        {
                            <span class="text-truncate" style="max-width:110px;" title="@b.Publisher">
                                @b.Publisher
                            </span>
                        }
                    </div>

                    @if (b.AvailableCopies > 0)
                    {
                        <a asp-controller="Member" asp-action="RequestBook" asp-route-bookId="@b.BookId"
                           class="btn btn-primary w-100 mb-2" style="font-size:13px;">
                            <i class="bi bi-send me-2"></i>Request This Book
                        </a>
                        <a asp-controller="Member" asp-action="RateBook" asp-route-bookId="@b.BookId"
                           class="btn btn-outline-warning w-100" style="font-size:13px;">
                            <i class="bi bi-star me-2"></i>Rate This Book
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Member" asp-action="ReserveBook" asp-route-bookId="@b.BookId"
                           class="btn btn-outline-danger w-100 mb-2" style="font-size:13px;">
                            <i class="bi bi-bookmark-plus me-2"></i>Reserve This Book
                        </a>
                        <button class="btn btn-outline-secondary w-100" disabled style="font-size:13px;">
                            <i class="bi bi-clock me-2"></i>Currently Unavailable
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- ── LIST VIEW (hidden by default) ─────────────────────────────────────── -->
<div id="listView" style="display:none;">
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="listTable">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Book No.</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Title</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Author</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Category</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Copies</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Status</th>
                            <th style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr class="book-list-item"
                                data-title="@b.Title.ToLower()"
                                data-author="@b.Author.ToLower()"
                                data-bookno="@b.BookNumber.ToLower()"
                                data-category="@(b.Category ?? "General")"
                                data-available="@(b.AvailableCopies > 0 ? "yes" : "no")">
                                <td class="px-4">
                                    <span class="badge bg-light text-dark border" style="font-family:monospace;font-size:12px;">@b.BookNumber</span>
                                </td>
                                <td>
                                    <div class="fw-medium" style="font-size:14px;">@b.Title</div>
                                    @if (!string.IsNullOrEmpty(b.Publisher))
                                    {
                                        <div class="text-muted" style="font-size:11px;">@b.Publisher</div>
                                    }
                                </td>
                                <td style="font-size:13px;">@b.Author</td>
                                <td style="font-size:13px;">@(b.Category ?? "—")</td>
                                <td style="font-size:13px;">
                                    <span class="@(b.AvailableCopies > 0 ? "text-success" : "text-danger") fw-medium">
                                        @b.AvailableCopies
                                    </span>
                                    <span class="text-muted">/ @b.TotalCopies</span>
                                </td>
                                <td>
                                    @if (b.AvailableCopies > 0)
                                    {
                                        <span class="badge bg-success-subtle text-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Unavailable</span>
                                    }
                                </td>
                                <td>
                                    @if (b.AvailableCopies > 0)
                                    {
                                        <a asp-controller="Member" asp-action="RequestBook" asp-route-bookId="@b.BookId"
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-send me-1"></i>Request
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled>Unavailable</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var activeCategory = 'all';
    var availableOnly  = false;
    var isGridView     = true;

    const searchInput   = document.getElementById('liveSearch');
    const clearBtn      = document.getElementById('clearSearch');
    const resultCount   = document.getElementById('resultCount');
    const noResults     = document.getElementById('noResults');
    const availToggle   = document.getElementById('availableOnly');
    const gridView      = document.getElementById('gridView');
    const listView      = document.getElementById('listView');
    const gridBtn       = document.getElementById('viewGrid');
    const listBtn       = document.getElementById('viewList');

    function applyFilters() {
        const q = searchInput.value.toLowerCase().trim();

        // Show/hide clear button
        clearBtn.style.display = q ? 'block' : 'none';

        // Grid items
        const gridItems = document.querySelectorAll('.book-item');
        // List items
        const listItems = document.querySelectorAll('.book-list-item');

        let visible = 0;

        function matchItem(el) {
            const title    = el.dataset.title    || '';
            const author   = el.dataset.author   || '';
            const bookno   = el.dataset.bookno   || '';
            const category = el.dataset.category || '';
            const avail    = el.dataset.available;

            const matchSearch = !q || title.includes(q) || author.includes(q) || bookno.includes(q);
            const matchCat    = activeCategory === 'all' || category === activeCategory;
            const matchAvail  = !availableOnly || avail === 'yes';

            return matchSearch && matchCat && matchAvail;
        }

        gridItems.forEach(el => {
            const show = matchItem(el);
            el.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        listItems.forEach(el => {
            el.style.display = matchItem(el) ? '' : 'none';
        });

        // Result count text
        const total = gridItems.length;
        if (q || activeCategory !== 'all' || availableOnly) {
            resultCount.textContent = `Showing ${visible} of ${total} books`;
        } else {
            resultCount.textContent = `Showing all ${total} books`;
        }

        // No results state
        noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    // Live search
    searchInput.addEventListener('input', applyFilters);

    // Clear button
    clearBtn.addEventListener('click', function () {
        searchInput.value = '';
        applyFilters();
        searchInput.focus();
    });

    // Available-only toggle
    availToggle.addEventListener('change', function () {
        availableOnly = this.checked;
        applyFilters();
    });

    // Category buttons
    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.category-btn').forEach(b => {
                b.classList.remove('active', 'btn-primary');
                b.classList.add('btn-outline-secondary');
            });
            this.classList.add('active', 'btn-primary');
            this.classList.remove('btn-outline-secondary');
            activeCategory = this.dataset.cat;
            applyFilters();
        });
    });

    // Grid / List view toggle
    gridBtn.addEventListener('click', function () {
        isGridView = true;
        gridView.style.display = '';
        listView.style.display = 'none';
        gridBtn.classList.add('active');
        listBtn.classList.remove('active');
    });

    listBtn.addEventListener('click', function () {
        isGridView = false;
        gridView.style.display = 'none';
        listView.style.display = '';
        listBtn.classList.add('active');
        gridBtn.classList.remove('active');
    });

    // Book card hover effect
    document.querySelectorAll('.book-card').forEach(card => {
        card.addEventListener('mouseenter', function () {
            this.style.transform = 'translateY(-3px)';
            this.style.boxShadow = '0 8px 24px rgba(0,0,0,0.12)';
        });
        card.addEventListener('mouseleave', function () {
            this.style.transform = '';
            this.style.boxShadow = '';
        });
    });

    // Run once on load to set initial state
    applyFilters();
})();
</script>
}
