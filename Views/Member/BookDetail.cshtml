@model MoDLibrary.Models.Book
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
    var ratings = ViewBag.Ratings as List<MoDLibrary.Models.BookRating> ?? new();
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Back to Catalog
    </a>
</div>

<div class="row g-4">
    <!-- Cover Image -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm" style="border-radius:12px;overflow:hidden;">
            @if (!string.IsNullOrEmpty(Model.CoverImagePath))
            {
                <img src="@Model.CoverImagePath" alt="@Model.Title"
                     style="width:100%;object-fit:cover;" />
            }
            else
            {
                <div style="height:300px;background:#f8fafc;display:flex;
                                align-items:center;justify-content:center;">
                    <i class="bi bi-book text-muted" style="font-size:72px;opacity:.3;"></i>
                </div>
            }
        </div>

        <!-- Availability -->
        <div class="card border-0 shadow-sm mt-3" style="border-radius:12px;">
            <div class="card-body p-3 text-center">
                @if (Model.AvailableCopies > 0)
                {
                    <div class="text-success fw-bold mb-1" style="font-size:18px;">
                        <i class="bi bi-check-circle-fill me-2"></i>Available
                    </div>
                    <div class="text-muted" style="font-size:13px;">
                        @Model.AvailableCopies of @Model.TotalCopies copies available
                    </div>
                    <div class="alert alert-success mt-2 mb-0 py-2" style="font-size:12px;">
                        <i class="bi bi-geo-alt me-1"></i>
                        Visit library — <strong>Rack @Model.RackLetter, @Model.ShelfCode</strong>
                    </div>
                }
                else
                {
                    <div class="text-danger fw-bold mb-1" style="font-size:16px;">
                        <i class="bi bi-x-circle-fill me-2"></i>Not Available
                    </div>

                    <div class="text-muted" style="font-size:13px;">
                        All copies are issued
                    </div>

                    @if (Model.DaysUntilAvailable.HasValue && Model.DaysUntilAvailable > 0)
                    {
                        <div class="alert alert-warning mt-2 mb-0 py-2" style="font-size:12px;">
                            <i class="bi bi-clock-history me-1"></i>
                            Available after <strong>@Model.DaysUntilAvailable days</strong>
                        </div>
                    }
                    else if (Model.EarliestDueDate.HasValue)
                    {
                        <div class="alert alert-warning mt-2 mb-0 py-2" style="font-size:12px;">
                            <i class="bi bi-calendar-event me-1"></i>
                            Expected on <strong>@Model.EarliestDueDate.Value.ToString("dd MMM yyyy")</strong>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Book Details -->
    <div class="col-md-9">
        <div class="card border-0 shadow-sm mb-3" style="border-radius:12px;">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <span class="badge bg-light text-dark border mb-2"
                              style="font-family:monospace;font-size:12px;">@Model.BookNumber</span>
                        <h3 class="fw-bold mb-1">@Model.Title</h3>
                        <div class="text-muted" style="font-size:15px;">by @Model.Author</div>
                    </div>
                    <span class="badge bg-light text-secondary border px-3 py-2">
                        @Model.Category
                    </span>
                </div>

                @if (Model.AvgRating > 0)
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <span style="color:@(s <= Math.Round(Model.AvgRating) ? "#f59e0b" : "#e2e8f0");font-size:20px;">★</span>
                        }
                        <span class="fw-bold">@Model.AvgRating.ToString("F1")</span>
                        <span class="text-muted" style="font-size:13px;">(@Model.TotalRatings reviews)</span>
                    </div>
                }

                <table class="table table-sm mb-0" style="font-size:13px;">
                    <tr>
                        <td class="text-muted" style="width:140px;">Publisher</td>
                        <td class="fw-medium">@(Model.Publisher ?? "—")</td>
                        <td class="text-muted" style="width:140px;">Published Year</td>
                        <td class="fw-medium">@(Model.PublishedYear?.ToString() ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">ISBN</td>
                        <td class="fw-medium">@(Model.ISBN ?? "—")</td>
                        <td class="text-muted">Total Copies</td>
                        <td class="fw-medium">@Model.TotalCopies</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Rack</td>
                        <td class="fw-medium">Rack @Model.RackLetter</td>
                        <td class="text-muted">Shelf</td>
                        <td class="fw-medium">@Model.ShelfCode</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Rate This Book -->
        <div class="card border-0 shadow-sm mb-3" style="border-radius:12px;">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-star me-2 text-warning"></i>
                    Rate This Book
                </h6>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Member" asp-action="RateBook" method="post">
                    <input type="hidden" name="BookId" value="@Model.BookId" />
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium" style="font-size:13px;">Your Name</label>
                            <input type="text" name="MemberName" class="form-control"
                                   placeholder="Full name" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium" style="font-size:13px;">CNIC</label>
                            <input type="text" name="CNIC" class="form-control"
                                   placeholder="XXXXX-XXXXXXX-X" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium" style="font-size:13px;">Rating</label>
                            <select name="Rating" class="form-select" required>
                                <option value="5">★★★★★ Excellent</option>
                                <option value="4">★★★★ Very Good</option>
                                <option value="3">★★★ Good</option>
                                <option value="2">★★ Fair</option>
                                <option value="1">★ Poor</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium" style="font-size:13px;">Review (Optional)</label>
                        <textarea name="Review" class="form-control" rows="2"
                                  placeholder="Share your thoughts..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-star me-2"></i>Submit Review
                    </button>
                </form>
            </div>
        </div>

        <!-- Reviews -->
        @if (ratings.Any())
        {
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-chat-quote me-2 text-primary"></i>
                        Member Reviews (@ratings.Count)
                    </h6>
                </div>
                <div class="card-body p-0">
                    @foreach (var r in ratings)
                    {
                        <div class="p-3 border-bottom">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <div class="fw-medium" style="font-size:13px;">@r.MemberName</div>
                                <div style="font-size:11px;color:#94a3b8;">
                                    @r.RatedAt.ToString("dd MMM yyyy")
                                </div>
                            </div>
                            <div class="mb-1">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span style="color:@(s <= r.Rating ? "#f59e0b" : "#e2e8f0");">★</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(r.Review))
                            {
                                <div class="text-muted" style="font-size:13px;">@r.Review</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
