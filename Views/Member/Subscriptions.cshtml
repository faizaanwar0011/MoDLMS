@model List<MoDLibrary.Models.LibrarySubscription>
@{
    ViewData["Title"] = "Library Subscriptions";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
    var settings = ViewBag.Settings as MoDLibrary.Models.SessionSettings
                   ?? new MoDLibrary.Models.SessionSettings();
    var sessionStatus = ViewBag.SessionStatus as MoDLibrary.Models.SessionResult
                        ?? new MoDLibrary.Models.SessionResult();
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">External Library Subscriptions</h4>
    <p class="text-muted mb-0">
        Access our partner libraries — each session is
        <strong>@settings.SessionDuration minutes</strong>.
        Maximum <strong>@settings.MaxConcurrentUsers</strong>
        concurrent users allowed.
    </p>
</div>

<!-- Active Session Banner -->
@if (sessionStatus.Status == "ACTIVE")
{
    <div class="alert alert-success d-flex align-items-center
        justify-content-between mb-4" role="alert">
        <div>
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Active Session:</strong> @sessionStatus.LibraryName
        </div>
        <a asp-action="ActiveSession"
               asp-route-sessionId="@sessionStatus.SessionId"
               class="btn btn-success btn-sm">
            <i class="bi bi-arrow-right me-1"></i>Continue Session
        </a>
    </div>
}

<!-- Queue Banner -->
@if (sessionStatus.Status == "QUEUED")
{
    <div class="alert alert-warning d-flex align-items-center
        justify-content-between mb-4">
        <div>
            <i class="bi bi-hourglass me-2"></i>
            <strong>You are #@sessionStatus.QueuePosition in queue</strong>
            — Estimated wait: ~@sessionStatus.WaitMinutes min
        </div>
        <a asp-action="QueueStatus" class="btn btn-warning btn-sm">
            <i class="bi bi-clock me-1"></i>Check Status
        </a>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-globe" style="font-size:64px;opacity:.3;"></i>
        <p class="mt-3">No subscriptions available yet.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var s in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100"
                     style="border-radius:12px;">
                    <div class="card-body p-4 text-center">
                        @if (!string.IsNullOrEmpty(s.LogoPath))
                        {
                            <img src="@s.LogoPath" alt="@s.LibraryName"
                                 style="height:60px;object-fit:contain;
                            margin-bottom:12px;" />
                        }
                        else
                        {
                            <div class="rounded-circle d-inline-flex
                                align-items-center justify-content-center mb-3"
                                 style="width:64px;height:64px;background:#e7f1ff;">
                                <i class="bi bi-globe text-primary"
                                   style="font-size:28px;"></i>
                            </div>
                        }
                        <h5 class="fw-bold mb-2">@s.LibraryName</h5>
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <p class="text-muted mb-3" style="font-size:13px;">
                                @s.Description
                            </p>
                        }

                        <div class="d-flex align-items-center
                            justify-content-center gap-2 mb-3"
                             style="font-size:12px;color:#6c757d;">
                            <i class="bi bi-clock"></i>
                            @settings.SessionDuration min session
                        </div>

                        @if (sessionStatus.Status == "ACTIVE")
                        {
                            <button class="btn btn-secondary w-100" disabled>
                                <i class="bi bi-lock me-2"></i>
                                Session Already Active
                            </button>
                        }
                        else if (sessionStatus.Status == "QUEUED")
                        {
                            <button class="btn btn-warning w-100" disabled>
                                <i class="bi bi-hourglass me-2"></i>
                                In Queue (#@sessionStatus.QueuePosition)
                            </button>
                        }
                        else
                        {
                            <form asp-action="StartSession" method="post">
                                <input type="hidden" name="subscriptionId"
                                       value="@s.SubscriptionId" />
                                <button type="submit"
                                        class="btn btn-primary w-100">
                                    <i class="bi bi-box-arrow-up-right me-2"></i>
                                    Access Library
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}