@model List<MoDLibrary.Models.LibrarySubscription>
@{
    ViewData["Title"] = "Library Subscriptions";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">External Library Subscriptions</h4>
    <p class="text-muted mb-0">
        Access our subscribed partner libraries — click any card to visit
    </p>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-globe" style="font-size:64px;opacity:.3;"></i>
        <p class="mt-3">No subscriptions available yet.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var s in Model)
        {
            <div class="col-md-6 col-lg-4">
                <a href="@s.WebsiteUrl" target="_blank" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100"
                         style="border-radius:12px;transition:transform .15s,box-shadow .15s;cursor:pointer;"
                         onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)'"
                         onmouseout="this.style.transform='';this.style.boxShadow=''">
                        <div class="card-body p-4 text-center">
                            @if (!string.IsNullOrEmpty(s.LogoPath))
                            {
                                <img src="@s.LogoPath" alt="@s.LibraryName"
                                     style="height:60px;object-fit:contain;margin-bottom:12px;" />
                            }
                            else
                            {
                                <div class="rounded-circle d-inline-flex align-items-center
                                                        justify-content-center mb-3"
                                     style="width:64px;height:64px;background:#e7f1ff;">
                                    <i class="bi bi-globe text-primary" style="font-size:28px;"></i>
                                </div>
                            }
                            <h5 class="fw-bold mb-2 text-dark">@s.LibraryName</h5>
                            @if (!string.IsNullOrEmpty(s.Description))
                            {
                                <p class="text-muted mb-3" style="font-size:13px;">@s.Description</p>
                            }
                            <div class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-box-arrow-up-right me-2"></i>Visit Library
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
