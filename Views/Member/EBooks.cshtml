@model List<MoDLibrary.Models.EBook>
@{
    ViewData["Title"] = "E-Books";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">E-Books Library</h4>
        <p class="text-muted mb-0">@Model.Count e-books available for reading and download</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-file-earmark-text" style="font-size:64px;opacity:.3;"></i>
        <p class="mt-3">No e-books available yet.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var e in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                    <div style="height:180px;overflow:hidden;background:#f8fafc;
                                        border-radius:12px 12px 0 0;display:flex;
                                        align-items:center;justify-content:center;">
                        @if (!string.IsNullOrEmpty(e.CoverImagePath))
                        {
                            <img src="@e.CoverImagePath" alt="@e.Title"
                                 style="width:100%;height:180px;object-fit:cover;" />
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-pdf text-danger"
                               style="font-size:56px;opacity:.5;"></i>
                        }
                    </div>
                    <div class="card-body p-3">
                        <span class="badge bg-danger-subtle text-danger mb-2" style="font-size:10px;">
                            <i class="bi bi-file-pdf me-1"></i>PDF
                        </span>
                        @if (!string.IsNullOrEmpty(e.FileSize))
                        {
                            <span class="badge bg-light text-secondary ms-1" style="font-size:10px;">
                                @e.FileSize
                            </span>
                        }
                        <h6 class="fw-semibold mb-1" style="font-size:13px;">@e.Title</h6>
                        <div class="text-muted mb-2" style="font-size:11px;">by @e.Author</div>
                        @if (!string.IsNullOrEmpty(e.Description))
                        {
                            <p class="text-muted mb-2" style="font-size:11px;line-height:1.4;">
                                @(e.Description.Length > 80 ? e.Description.Substring(0, 80) + "…" : e.Description)
                            </p>
                        }
                        <div class="d-grid gap-2 mt-auto">
                            <a href="@e.FilePath" target="_blank"
                               class="btn btn-primary btn-sm">
                                <i class="bi bi-eye me-2"></i>Read Online
                            </a>
                            <a href="@e.FilePath" download
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-download me-2"></i>Download PDF
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
