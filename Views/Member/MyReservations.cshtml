@model List<MoDLibrary.Models.Reservation>
@{
    ViewData["Title"] = "My Reservations";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-bold mb-1">My Reservations</h4>
    <p class="text-muted mb-0" style="font-size:14px;">
        Enter your CNIC to check your book reservations
    </p>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-4">
        <form asp-action="MyReservations" method="get">
            <div class="d-flex gap-3">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-credit-card-2-front text-muted"></i>
                        </span>
                        <input type="text" name="cnic" value="@ViewBag.CNIC"
                               class="form-control border-start-0"
                               placeholder="Enter your CNIC"
                               style="font-size:14px;" maxlength="15" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search me-2"></i>Check
                </button>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.CNIC != "")
{
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bookmark-x" style="font-size:48px;opacity:.3;"></i>
            <p class="mt-3">No reservations found.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var r in Model)
            {
                var bc = r.Status == "Notified" ? "#16a34a" :
                r.Status == "Waiting" ? "#d97706" : "#94a3b8";
                <div class="card border-0 shadow-sm"
                     style="border-radius:12px;border-left:4px solid @bc !important;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
                            <div>
                                <div class="fw-bold" style="font-size:15px;">@r.BookTitle</div>
                                <div class="text-muted" style="font-size:12px;">@r.BookNumber</div>
                                <div class="text-muted mt-1" style="font-size:12px;">
                                    Reserved: @r.ReservedAt.ToString("dd MMM yyyy")
                                </div>
                            </div>
                            @switch (r.Status)
                            {
                                case "Waiting":
                                    <span class="badge bg-warning text-dark px-3 py-2">
                                        <i class="bi bi-hourglass me-1"></i>Waiting
                                    </span>
                                    break;
                                case "Notified":
                                    <span class="badge bg-success px-3 py-2">
                                        <i class="bi bi-bell me-1"></i>Ready — Collect Now!
                                    </span>
                                    break;
                                case "Collected":
                                    <span class="badge bg-primary px-3 py-2">Collected</span>
                                    break;
                                case "Expired":
                                    <span class="badge bg-secondary px-3 py-2">Expired</span>
                                    break;
                                case "Cancelled":
                                    <span class="badge bg-danger px-3 py-2">Cancelled</span>
                                    break;
                            }
                        </div>
                        @if (r.Status == "Notified")
                        {
                            <div class="alert alert-success d-flex gap-2 mt-3 mb-0"
                                 style="font-size:13px;">
                                <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
                                <div>
                                    <strong>Your book is available!</strong>
                                    Please collect it before
                                    <strong>@r.ExpiryDate?.ToString("dd MMM yyyy")</strong>
                                    or your reservation will expire.
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
}@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
