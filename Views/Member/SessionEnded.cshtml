@{
}
@{
    ViewData["Title"] = "Session Ended";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm text-center"
             style="border-radius:16px;">
            <div class="card-body p-5">
                <div class="d-inline-flex align-items-center
                    justify-content-center rounded-circle mb-4"
                     style="width:80px;height:80px;background:#fef3c7;">
                    <i class="bi bi-clock-history text-warning"
                       style="font-size:36px;"></i>
                </div>

                <h4 class="fw-bold mb-2">Your Session Has Concluded</h4>
                <p class="text-muted mb-4" style="font-size:14px;">
                    Your allocated time for accessing the external library
                    has ended. We hope you found what you were looking for.
                </p>

                <div class="alert alert-info mb-4" style="font-size:13px;">
                    <i class="bi bi-info-circle me-2"></i>
                    If you need more time, you may request a new session.
                    Other members in the queue will be given priority.
                </div>

                <div class="d-flex gap-3 justify-content-center">
                    <a asp-action="Subscriptions"
                           class="btn btn-primary px-4">
                        <i class="bi bi-arrow-repeat me-2"></i>
                        Request New Session
                    </a>
                    <a asp-action="Index" asp-controller="Member"
                           class="btn btn-outline-secondary px-4">
                        <i class="bi bi-house me-2"></i>
                        Back to Catalog
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>