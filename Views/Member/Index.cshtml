@model List<MoDLibrary.Models.Book>
@{
    ViewData["Title"] = "Library Catalog";
    Layout = "~/Views/Shared/_MemberLayout.cshtml";
    var categories = ViewBag.Categories as List<MoDLibrary.Models.Category> ?? new();
}

<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 class="fw-bold mb-1">Library Catalog</h4>
        <p class="text-muted mb-0" style="font-size:14px;">
            <span class="text-success fw-medium">@Model.Count(b => b.AvailableCopies > 0) available</span>
            out of <strong>@Model.Count</strong> books
        </p>
    </div>
    <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
        <input class="form-check-input" type="checkbox" id="availableOnly" style="cursor:pointer;">
        <label class="form-check-label text-muted" for="availableOnly" style="font-size:13px;cursor:pointer;">
            Available only
        </label>
    </div>
</div>

<!-- Search Bar -->
<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-3">
        <div class="input-group input-group-lg">
            <span class="input-group-text bg-white border-end-0 ps-3">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="liveSearch"
                   class="form-control border-start-0 ps-1"
                   placeholder="Search by title, author, or book number…"
                   value="@ViewBag.Query"
                   style="font-size:15px;" />
            <button class="btn btn-outline-secondary border-start-0"
                    id="clearSearch" style="display:none;" type="button">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>
</div>

<!-- Category Filter -->
<div class="mb-4 d-flex flex-wrap gap-2" id="categoryFilters">
    <button class="btn btn-primary btn-sm category-btn active" data-cat="all">
        All <span class="badge bg-white text-primary ms-1">@Model.Count</span>
    </button>
    @foreach (var cat in categories)
    {
        var count = Model.Count(b => b.Category == cat.CategoryName);
        if (count > 0)
        {
            <button class="btn btn-outline-secondary btn-sm category-btn" data-cat="@cat.CategoryName">
                @cat.CategoryName
                <span class="badge bg-secondary ms-1">@count</span>
            </button>
        }
    }
</div>

<!-- Result Count + View Toggle -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <small class="text-muted" id="resultCount">Showing all @Model.Count books</small>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary active" id="viewGrid">
            <i class="bi bi-grid-3x3-gap"></i>
        </button>
        <button class="btn btn-sm btn-outline-secondary" id="viewList">
            <i class="bi bi-list-ul"></i>
        </button>
    </div>
</div>

<!-- No Results -->
<div id="noResults" class="text-center py-5" style="display:none;">
    <i class="bi bi-journal-x text-muted" style="font-size:56px;opacity:.3;"></i>
    <p class="text-muted mt-3 mb-0 fw-medium">No books match your search.</p>
</div>

<!-- Grid View -->
<div id="gridView" class="row g-3">
    @foreach (var b in Model)
    {
        <div class="col-md-6 col-lg-3 book-item"
             data-title="@b.Title.ToLower()"
             data-author="@b.Author.ToLower()"
             data-bookno="@b.BookNumber.ToLower()"
             data-category="@b.Category"
             data-available="@(b.AvailableCopies > 0 ? "yes" : "no")">
            <div class="card border-0 shadow-sm h-100"
                 style="border-radius:12px;transition:transform .15s,box-shadow .15s;cursor:pointer;"
                 onclick="window.location='/Member/BookDetail/@b.BookId'">
                <!-- Color stripe -->
                <div style="height:4px;border-radius:12px 12px 0 0;
                                background:@(b.AvailableCopies > 0 ? "#16a34a" : "#dc2626");"></div>

                <!-- Cover Image -->
                <div style="height:160px;overflow:hidden;background:#f8fafc;
                                border-radius:0;display:flex;align-items:center;justify-content:center;">
                    @if (!string.IsNullOrEmpty(b.CoverImagePath))
                    {
                        <img src="@b.CoverImagePath" alt="@b.Title"
                             style="width:100%;height:160px;object-fit:cover;" />
                    }
                    else
                    {
                        <i class="bi bi-book text-muted" style="font-size:48px;opacity:.3;"></i>
                    }
                </div>

                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <span class="badge bg-light text-dark border"
                              style="font-family:monospace;font-size:10px;">@b.BookNumber</span>
                        @if (b.AvailableCopies > 0)
                        {
                            <span class="badge bg-success-subtle text-success" style="font-size:10px;">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger" style="font-size:10px;">Unavailable</span>
                        }
                    </div>
                    <h6 class="fw-semibold mb-1 mt-2" style="font-size:13px;line-height:1.3;">@b.Title</h6>
                    <div class="text-muted" style="font-size:11px;">@b.Author</div>

                    @if (b.AvgRating > 0)
                    {
                        <div class="mt-1" style="font-size:11px;color:#f59e0b;">
                            ★ @b.AvgRating.ToString("F1")
                            <span class="text-muted">(@b.TotalRatings)</span>
                        </div>
                    }

                    <div class="mt-2">
                        <span class="badge bg-light text-secondary border" style="font-size:10px;">
                            <i class="bi bi-geo-alt me-1"></i>Rack @b.RackLetter — @b.ShelfCode
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- List View -->
<div id="listView" style="display:none;">
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="px-4 py-3" style="font-size:11px;text-transform:uppercase;color:#6c757d;">Cover</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Book</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Category</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Location</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Copies</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Status</th>
                            <th style="font-size:11px;text-transform:uppercase;color:#6c757d;">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr class="book-list-item"
                                data-title="@b.Title.ToLower()"
                                data-author="@b.Author.ToLower()"
                                data-bookno="@b.BookNumber.ToLower()"
                                data-category="@b.Category"
                                data-available="@(b.AvailableCopies > 0 ? "yes" : "no")">
                                <td class="px-4">
                                    @if (!string.IsNullOrEmpty(b.CoverImagePath))
                                    {
                                        <img src="@b.CoverImagePath" alt="@b.Title"
                                             style="width:36px;height:48px;object-fit:cover;border-radius:4px;" />
                                    }
                                    else
                                    {
                                        <div style="width:36px;height:48px;background:#f1f5f9;
                                                            border-radius:4px;display:flex;align-items:center;
                                                            justify-content:center;">
                                            <i class="bi bi-book text-muted" style="font-size:16px;"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-medium" style="font-size:13px;">@b.Title</div>
                                    <div class="text-muted" style="font-size:11px;">@b.Author</div>
                                    <div class="text-muted" style="font-size:10px;font-family:monospace;">@b.BookNumber</div>
                                </td>
                                <td style="font-size:12px;">@b.Category</td>
                                <td>
                                    <span class="badge bg-info-subtle text-info" style="font-size:11px;">
                                        <i class="bi bi-geo-alt me-1"></i>Rack @b.RackLetter — @b.ShelfCode
                                    </span>
                                </td>
                                <td style="font-size:12px;">
                                    <span class="@(b.AvailableCopies > 0 ? "text-success" : "text-danger") fw-medium">
                                        @b.AvailableCopies
                                    </span> / @b.TotalCopies
                                </td>
                                <td>
                                    @if (b.AvailableCopies > 0)
                                    {
                                        <span class="badge bg-success-subtle text-success">Available</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger-subtle text-danger">Unavailable</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="BookDetail" asp-route-id="@b.BookId"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var activeCategory = 'all';
            var availableOnly  = false;

            const searchInput  = document.getElementById('liveSearch');
            const clearBtn     = document.getElementById('clearSearch');
            const resultCount  = document.getElementById('resultCount');
            const noResults    = document.getElementById('noResults');
            const availToggle  = document.getElementById('availableOnly');
            const gridView     = document.getElementById('gridView');
            const listView     = document.getElementById('listView');
            const gridBtn      = document.getElementById('viewGrid');
            const listBtn      = document.getElementById('viewList');

            function applyFilters() {
                const q = searchInput.value.toLowerCase().trim();
                clearBtn.style.display = q ? 'block' : 'none';
                const gridItems = document.querySelectorAll('.book-item');
                const listItems = document.querySelectorAll('.book-list-item');
                let visible = 0;

                function match(el) {
                    const matchSearch = !q || el.dataset.title.includes(q) ||
                        el.dataset.author.includes(q) || el.dataset.bookno.includes(q);
                    const matchCat   = activeCategory === 'all' || el.dataset.category === activeCategory;
                    const matchAvail = !availableOnly || el.dataset.available === 'yes';
                    return matchSearch && matchCat && matchAvail;
                }

                gridItems.forEach(el => {
                    const show = match(el);
                    el.style.display = show ? '' : 'none';
                    if (show) visible++;
                });
                listItems.forEach(el => {
                    el.style.display = match(el) ? '' : 'none';
                });

                const total = gridItems.length;
                resultCount.textContent = (q || activeCategory !== 'all' || availableOnly)
                    ? `Showing ${visible} of ${total} books`
                    : `Showing all ${total} books`;
                noResults.style.display = visible === 0 ? 'block' : 'none';
            }

            searchInput.addEventListener('input', applyFilters);
            clearBtn.addEventListener('click', () => { searchInput.value = ''; applyFilters(); searchInput.focus(); });
            availToggle.addEventListener('change', function() { availableOnly = this.checked; applyFilters(); });

            document.querySelectorAll('.category-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.category-btn').forEach(b => {
                        b.classList.remove('active','btn-primary');
                        b.classList.add('btn-outline-secondary');
                    });
                    this.classList.add('active','btn-primary');
                    this.classList.remove('btn-outline-secondary');
                    activeCategory = this.dataset.cat;
                    applyFilters();
                });
            });

            gridBtn.addEventListener('click', () => {
                gridView.style.display = ''; listView.style.display = 'none';
                gridBtn.classList.add('active'); listBtn.classList.remove('active');
            });
            listBtn.addEventListener('click', () => {
                gridView.style.display = 'none'; listView.style.display = '';
                listBtn.classList.add('active'); gridBtn.classList.remove('active');
            });

            document.querySelectorAll('.book-card, .card').forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-3px)';
                    this.style.boxShadow = '0 8px 24px rgba(0,0,0,0.12)';
                });
                card.addEventListener('mouseleave', function() {
                    this.style.transform = '';
                    this.style.boxShadow = '';
                });
            });

            applyFilters();
        })();
    </script>
}
